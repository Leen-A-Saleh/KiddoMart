@model IEnumerable<All_Baby_Essentials.Models.Testimonial>

@{
    ViewData["Title"] = "Testimonials Moderation";
}

<div class="category-dashboard-container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 px-3">
        <div>
            <h2 class="mb-1" style="font-weight: 800; color: #2b3445; letter-spacing: -0.5px;">
                <i class="fas fa-quote-left text-primary mr-2" style="background: linear-gradient(135deg, #a1c4fd 0%, #c2e9fb 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i> 
                Testimonials Moderation
            </h2>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Review, approve, or reject customer testimonials displayed on the homepage.</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning rounded-lg shadow-sm border-0 d-flex align-items-center p-4">
            <i class="fas fa-quote-right fa-2x mr-3 text-warning"></i>
            <div>
                <h5 class="mb-1 font-weight-bold">No Testimonials Found</h5>
                <p class="mb-0 text-muted">There are currently no customer testimonials submitted.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 km-card-glass shadow-lg">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table km-vibrant-table mb-0">
                        <thead>
                            <tr>
                                <th>Customer</th>
                                <th>Rating</th>
                                <th>Testimonial Feedback</th>
                                <th>Status</th>
                                <th class="text-center" style="width: 150px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="km-table-row">
                                    <td class="align-middle">
                                        <div class="d-flex align-items-center">
                                            <div class="km-avatar-initial mr-3" style="background: linear-gradient(135deg, #a1c4fd 0%, #c2e9fb 100%); color: #4a5568; box-shadow: 0 4px 10px rgba(161, 196, 253, 0.4);">
                                                @(string.IsNullOrWhiteSpace(item.User?.FullName) ? "U" : string.Concat(item.User.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(word => char.ToUpper(word[0]))))
                                            </div>
                                            <div>
                                                <h6 class="mb-0 font-weight-bold text-dark">@(item.User?.FullName ?? "Guest User")</h6>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="align-middle">
                                        <div class="d-flex align-items-center gap-1">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fas fa-star @(i <= item.Rating ? "text-warning" : "text-muted opacity-25")" style="font-size:11px;"></i>
                                            }
                                            <span class="text-muted text-sm ml-2">(@item.Rating)</span>
                                        </div>
                                    </td>
                                    <td class="align-middle" style="max-width:380px;">
                                        <span class="text-sm d-block text-muted font-weight-bold" style="white-space:normal;">@item.Content</span>
                                    </td>
                                    <td class="align-middle">
                                        <span class="badge @(item.IsApproved ? "badge-success" : "badge-warning")" style="padding: 0.4rem 0.6rem; border-radius: 6px;">
                                            @(item.IsApproved ? "Approved" : "Pending")
                                        </span>
                                    </td>
                                    <td class="text-center align-middle">
                                        <form asp-action="ToggleTestimonialStatus" method="post" class="d-inline m-0">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            @if (item.IsApproved)
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-warning w-100 font-weight-bold" style="border-radius: 8px;">
                                                    <i class="fas fa-times mr-1"></i> Reject
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm km-btn-gradient w-100 font-weight-bold" style="background: linear-gradient(135deg, #a1c4fd 0%, #c2e9fb 100%); color: #4a5568; border: none; box-shadow: 0 4px 10px rgba(161, 196, 253, 0.3); border-radius: 8px;">
                                                    <i class="fas fa-check mr-1"></i> Approve
                                                </button>
                                            }
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>