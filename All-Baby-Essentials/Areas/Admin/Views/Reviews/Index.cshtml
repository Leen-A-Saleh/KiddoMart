@model IEnumerable<All_Baby_Essentials.Areas.Admin.ViewModels.ProductReviewVM>


@{
    ViewData["Title"] = "Product Reviews";
}

@section Title { Reviews }
@section SubTitle { Product Reviews }

@section ActionBtn {
    <h5 class="mb-0 fw-semibold">Product Reviews Moderation</h5>
}

<div class="card-body">
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Customer</th>
                    <th>Product</th>
                    <th>Rating</th>
                    <th>Comment</th>
                    <th>Status</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="text-sm fw-semibold">@item.User?.FullName</span></td>
                        <td><span class="text-sm">@item.Product?.Name</span></td>
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fas fa-star @(i <= item.Rating ? "text-warning" : "text-muted opacity-25")" style="font-size:11px;"></i>
                                }
                                <span class="text-muted text-sm ms-1">(@item.Rating)</span>
                            </div>
                        </td>
                        <td style="max-width:280px;">
                            <span class="text-sm d-block text-truncate" title="@item.Comment">@item.Comment</span>
                        </td>
                        <td>
                            <span class="badge @(item.IsApproved ? "bg-success" : "bg-secondary")">
                                @(item.IsApproved ? "Approved" : "Pending")
                            </span>
                        </td>
                        <td class="text-center">
                            <form asp-action="ToggleReviewStatus" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit"
                                        class="btn btn-sm @(item.IsApproved ? "btn-outline-warning" : "btn-outline-success")">
                                    <i class="fas @(item.IsApproved ? "fa-times" : "fa-check") me-1"></i>
                                    @(item.IsApproved ? "Reject" : "Approve")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="fas fa-star fa-3x mb-3 opacity-25"></i>
                <p>No product reviews yet.</p>
            </div>
        }
    </div>
</div>
