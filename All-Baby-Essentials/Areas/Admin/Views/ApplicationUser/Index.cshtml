@model List<All_Baby_Essentials.Areas.Admin.ViewModels.ApplicationUserVM>

@{
    ViewData["Title"] = "User Management";
}

<div class="category-dashboard-container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 px-3">
        <div>
            <h2 class="mb-1" style="font-weight: 800; color: #2b3445; letter-spacing: -0.5px;">
                <i class="fas fa-users text-primary mr-2" style="background: linear-gradient(135deg, #abecd6 0%, #fbed96 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i> 
                User Management
            </h2>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Manage store customers, administrators, and guest profiles.</p>
        </div>
        <div class="bg-white border rounded-lg px-4 py-2 shadow-sm d-flex align-items-center" style="border-radius: 12px;">
            <i class="fas fa-user-friends text-info mr-2 fa-lg"></i>
            <div>
                <small class="text-muted text-uppercase font-weight-bold d-block" style="font-size: 0.7rem; letter-spacing: 0.5px;">Total Users</small>
                <h5 class="mb-0 font-weight-bold text-dark">@Model.Count</h5>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning rounded-lg shadow-sm border-0 d-flex align-items-center p-4">
            <i class="fas fa-user-slash fa-2x mr-3 text-warning"></i>
            <div>
                <h5 class="mb-1 font-weight-bold">No Users Found</h5>
                <p class="mb-0 text-muted">There are no registered user profiles in the database.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 km-card-glass shadow-lg">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table km-vibrant-table mb-0">
                        <thead>
                            <tr>
                                <th>Full Name</th>
                                <th>Email Address</th>
                                <th class="text-center" style="width: 120px;">Gender</th>
                                <th>Date of Birth</th>
                                <th class="text-center" style="width: 150px;">Role</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr class="km-table-row">
                                    <td class="align-middle">
                                        <div class="d-flex align-items-center">
                                            <div class="km-avatar-initial mr-3" style="background: linear-gradient(135deg, #abecd6 0%, #fbed96 100%); color: #4a5568; box-shadow: 0 4px 10px rgba(171, 236, 214, 0.4);">
                                                @if (!string.IsNullOrWhiteSpace(user.FullName))
                                                {
                                                    @string.Concat(user.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(word => char.ToUpper(word[0])))
                                                }
                                                else
                                                {
                                                    <i class="fas fa-user"></i>
                                                }
                                            </div>
                                            <div>
                                                <h6 class="mb-0 font-weight-bold text-dark">@user.FullName</h6>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="align-middle font-weight-bold text-muted">@user.Email</td>
                                    <td class="align-middle text-center">
                                        @if (user.Gender == All_Baby_Essentials.Models.ApplicationUserGender.M)
                                        {
                                            <span class="badge badge-primary" style="padding: 0.4rem 0.6rem; border-radius: 6px;"><i class="fas fa-mars mr-1"></i> Male</span>
                                        }
                                        else if (user.Gender == All_Baby_Essentials.Models.ApplicationUserGender.F)
                                        {
                                            <span class="badge" style="padding: 0.4rem 0.6rem; border-radius: 6px; background-color: #ec4899; color: white;"><i class="fas fa-venus mr-1"></i> Female</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary" style="padding: 0.4rem 0.6rem; border-radius: 6px;">@user.Gender</span>
                                        }
                                    </td>
                                    <td class="align-middle text-muted">
                                        @(user.DateOfBirth == default ? "—" : user.DateOfBirth.ToString("MMM dd, yyyy"))
                                    </td>
                                    <td class="align-middle text-center">
                                        @if (user.Role == "Admin")
                                        {
                                            <span class="badge badge-danger text-uppercase font-weight-bold" style="padding: 0.4rem 0.6rem; border-radius: 6px; letter-spacing: 0.5px;">Admin</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-success text-uppercase font-weight-bold" style="padding: 0.4rem 0.6rem; border-radius: 6px; letter-spacing: 0.5px;">Customer</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>