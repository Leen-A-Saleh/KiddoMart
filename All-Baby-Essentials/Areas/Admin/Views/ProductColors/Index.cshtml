@model IEnumerable<All_Baby_Essentials.Areas.Admin.ViewModels.ProductColorVM>
@{
    ViewData["Title"] = "Product Colors";
    var product = ViewBag.Product as All_Baby_Essentials.Models.Product;
}

@section Title {
    Products
}

@section SubTitle {
    Colors & Stock for @(product?.Name)
}

@section ActionBtn {
    <a asp-controller="Products" asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back to Products
    </a>
}

<div class="row p-3">
    <!-- Left Column: Add Color Variant -->
    <div class="col-md-4">
        <div class="card border-0 km-card-glass shadow-lg">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h5 class="card-title m-0 fw-bold" style="color: #2b3445;"><i class="fas fa-plus-circle mr-2" style="color: #00c2a8;"></i> Add Color Variant</h5>
            </div>
            <form asp-controller="ProductColors" asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@product?.Id" />

                <div class="card-body">
                    <!-- Standard Colors Dropdown -->
                    <div class="form-group mb-4" id="standardColorGroup">
                        <label class="form-label font-weight-bold text-dark">Select Color</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-white border-right-0"><i class="fas fa-palette text-muted"></i></span>
                            </div>
                            <select name="colorId" asp-items="ViewBag.ColorsList" class="form-control border-left-0 km-input" style="box-shadow:none;">
                                <option value="">-- Choose Standard Color --</option>
                            </select>
                        </div>
                        <small class="text-muted">Select an existing color from the standard list.</small>
                    </div>

                    <!-- Toggle Custom Color -->
                    <div class="form-group form-check mb-4 pl-0">
                        <div class="custom-control custom-checkbox">
                            <input type="checkbox" class="custom-control-input" id="toggleCustomColor" onchange="toggleCustomColorInputs(this)" />
                            <label class="custom-control-label font-weight-bold cursor-pointer text-dark" for="toggleCustomColor">Or create a new color globally</label>
                        </div>
                    </div>

                    <!-- Custom Color Fields (hidden by default) -->
                    <div id="customColorFields" style="display: none;" class="p-3 bg-light border rounded-lg mb-4">
                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold text-dark">Color Name</label>
                            <input type="text" name="newColorName" class="form-control km-input" placeholder="e.g. Lavender" style="box-shadow:none;" />
                        </div>
                        <div class="form-group mb-2">
                            <label class="form-label font-weight-bold text-dark">Color Hex Code</label>
                            <input type="color" name="newColorHexCode" class="form-control form-control-color w-100 border-0 p-0" value="#FF0000" style="height:42px; border-radius:10px; cursor:pointer;" />
                            <small class="text-muted">Pick color or specify hex code.</small>
                        </div>
                    </div>

                    <!-- Stock Quantity -->
                    <div class="form-group mb-4">
                        <label class="form-label font-weight-bold text-dark">Stock Quantity</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-white border-right-0"><i class="fas fa-cubes text-muted"></i></span>
                            </div>
                            <input type="number" name="stockQuantity" class="form-control border-left-0 km-input" placeholder="0" min="0" required style="box-shadow:none;" />
                        </div>
                    </div>

                    <!-- Color Specific Image -->
                    <div class="form-group mb-4">
                        <label class="form-label font-weight-bold text-dark">Variant Image (Optional)</label>
                        <div class="custom-file-upload border rounded p-3 text-center bg-light" style="border: 2px dashed #cbd5e1 !important; border-radius: 12px !important; transition: all 0.3s ease;">
                            <input type="file" name="imageFile" id="imageFile" class="d-none" accept="image/*" onchange="previewImage(event)" />
                            
                            <div id="uploadPromptColor">
                                <i class="fas fa-cloud-upload-alt fa-2x text-muted mb-2"></i>
                                <h6 class="mb-1 font-weight-bold small text-dark">Upload Variant Image</h6>
                                <label for="imageFile" class="btn btn-outline-primary btn-xs px-3" style="border-radius: 8px; cursor: pointer; font-size:0.75rem;">Browse</label>
                            </div>
                            
                            <!-- Preview Thumbnail -->
                            <div id="variantPreviewContainer" style="display:none;" class="mt-2">
                                <img id="variantPreview" src="#" alt="Preview" class="img-fluid rounded shadow-sm" style="max-height: 100px; object-fit: contain;" />
                                <br/>
                                <label for="imageFile" class="btn btn-xs btn-outline-secondary mt-2" style="border-radius: 8px; cursor: pointer; font-size:0.75rem;"><i class="fas fa-exchange-alt mr-1"></i> Change</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-top-0 pb-4">
                    <button type="submit" class="btn km-btn-gradient w-100 py-2" style="background: linear-gradient(135deg, #00c2a8 0%, #00a890 100%); box-shadow: 0 6px 15px rgba(0, 194, 168, 0.3); font-size: 1rem;">
                        <i class="fas fa-plus-circle mr-2"></i> Add Color Variant
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Right Column: Current Variants Table -->
    <div class="col-md-8">
        <div class="card border-0 km-card-glass shadow-lg">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h5 class="card-title m-0 fw-bold" style="color: #2b3445;"><i class="fas fa-palette mr-2" style="color:#8b5cf6;"></i> Current Color Variants</h5>
            </div>
            <div class="card-body p-0">
                @if (!Model.Any())
                {
                    <div class="p-4 text-center">
                        <i class="fas fa-exclamation-triangle text-warning fa-2x mb-3"></i>
                        <h5>No color variants found for this product.</h5>
                        <p class="text-muted">Please use the form on the left to add colors and inventory.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table km-vibrant-table m-0">
                            <thead>
                                <tr>
                                    <th style="width: 100px" class="text-center">Swatch</th>
                                    <th>Color Name</th>
                                    <th>Color HEX</th>
                                    <th style="width: 120px">Stock</th>
                                    <th style="width: 120px" class="text-center">Image</th>
                                    <th style="width: 150px" class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr class="km-table-row">
                                        <td class="text-center align-middle">
                                            <div class="rounded-circle border shadow-sm mx-auto" style="width: 38px; height: 38px; background-color: @item.ColorHexCode;"></div>
                                        </td>
                                        <td class="align-middle"><strong>@item.ColorName</strong></td>
                                        <td class="align-middle"><code style="background: #f1f5f9; padding: 4px 8px; border-radius: 6px;">@item.ColorHexCode</code></td>
                                        <td class="align-middle">
                                            @if (item.StockQuantity == 0)
                                            {
                                                <span class="badge badge-danger" style="padding: 0.4rem 0.6rem; border-radius: 6px;">Out of Stock</span>
                                            }
                                            else if (item.StockQuantity < 10)
                                            {
                                                <span class="badge badge-warning" style="padding: 0.4rem 0.6rem; border-radius: 6px;">@item.StockQuantity Left</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-success" style="padding: 0.4rem 0.6rem; border-radius: 6px;">@item.StockQuantity in Stock</span>
                                            }
                                        </td>
                                        <td class="text-center align-middle">
                                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                                            {
                                                <img src="/img/@item.ImageUrl" alt="Variant Image" class="img-thumbnail rounded" style="width: 50px; height: 50px; object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <span class="text-muted small">None</span>
                                            }
                                        </td>
                                        <td class="text-center align-middle">
                                            <div class="km-action-group">
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="km-icon-btn km-edit" title="Edit Variant">
                                                    <i class="fas fa-pen"></i>
                                                </a>
                                                <button type="button" class="km-icon-btn km-delete js-delete-variant" data-id="@item.Id" title="Delete Variant">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
            <div class="card-footer bg-light border-top-0" style="border-radius: 0 0 20px 20px;">
                <div class="d-flex justify-content-between align-items-center px-2 py-1">
                    <span class="text-muted small">Total Variant Types: <strong>@Model.Count()</strong></span>
                    <span class="text-muted small">Sum of Stock: <strong>@(product?.StockQuantity ?? 0)</strong></span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleCustomColorInputs(checkbox) {
            const dropdownGroup = document.getElementById('standardColorGroup');
            const customFields = document.getElementById('customColorFields');
            const dropdown = dropdownGroup.querySelector('select');
            const customInputs = customFields.querySelectorAll('input');

            if (checkbox.checked) {
                dropdownGroup.style.display = 'none';
                dropdown.value = '';
                dropdown.removeAttribute('required');
                customFields.style.display = 'block';
                customInputs.forEach(i => i.setAttribute('required', 'true'));
            } else {
                dropdownGroup.style.display = 'block';
                dropdown.setAttribute('required', 'true');
                customFields.style.display = 'none';
                customInputs.forEach(i => {
                    i.removeAttribute('required');
                    i.value = i.type === 'color' ? '#FF0000' : '';
                });
            }
        }

        function previewImage(event) {
            const input = event.target;
            const previewContainer = document.getElementById('variantPreviewContainer');
            const previewImg = document.getElementById('variantPreview');

            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    previewContainer.style.display = 'block';
                }
                reader.readAsDataURL(input.files[0]);
            } else {
                previewImg.src = '#';
                previewContainer.style.display = 'none';
            }
        }

        document.querySelectorAll(".js-delete-variant").forEach((btn) => {
            btn.addEventListener("click", async (event) => {
                event.preventDefault();

                const result = await Swal.fire({
                    title: "Are you sure?",
                    text: "This will remove the color variant and subtract its stock!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#d33",
                    cancelButtonColor: "#3085d6",
                    confirmButtonText: "Yes, delete it!"
                });

                if (result.isConfirmed) {
                    const id = btn.dataset.id;
                    const response = await fetch(
                        '@Url.Action("Delete", "ProductColors", new { area = "Admin" })/' + id,
                        { method: "POST" }
                    );

                    if (response.ok) {
                        const Toast = Swal.mixin({
                            toast: true, position: "top-end",
                            showConfirmButton: false, timer: 3000, timerProgressBar: true
                        });
                        Toast.fire({ icon: "success", title: "Variant deleted successfully" }).then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire({ icon: "error", title: "Error", text: "Something went wrong." });
                    }
                }
            });
        });
    </script>
}
