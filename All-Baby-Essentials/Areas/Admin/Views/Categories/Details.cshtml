@model All_Baby_Essentials.Areas.Admin.ViewModels.CategoryVM

@{
    ViewData["Title"] = "Details";
}

@section Title {
    Categories
} 

@section SubTitle {
    Details of @Model.Name
}

<div class="card-body">
    <table class="table table-bordered">
        <thead>
            <tr>
                <th style="width: 10px">#</th>
                <th>Name</th>
                <th>Description</th>
                <th style="width:150px">Image</th>
                <th>Created At</th>
                <th>Updated At</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>@Model.Id</td>
                <td>@Model.Name</td>
                <td>@Model.Description</td>
                <td>
                    @if (!string.IsNullOrEmpty(@Model.ImageUrl))
                    {
                        <div>
                            <img src="@Url.Content("~/img/" + @Model.ImageUrl)"
                                 alt="@Model.Name Category"
                                 class="img-fluid img-thumbnail" />
                        </div>
                    }
                </td>
                <td>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>@Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>
                    <a asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-sm btn-primary">
                        <i class="fas fa-edit"></i> Edit
                    </a>
                    <a href="#" class="btn btn-sm btn-danger js-deleted" data-id="@Model.Id">
                        <i class="fas fa-trash"></i> Delete
                    </a>
                </td>
            </tr>
        </tbody>
    </table>

    @if (Model.Products.Any())
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Product Name</th>
                    <th width="150">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model.Products)
                {
                    <tr>
                        <td>@product.Name</td>
                        <td>
                            <a asp-area="Admin" asp-controller="Products" asp-action="Details"  asp-route-id="@product.Id"
                               class="btn btn-sm btn-primary">
                                <i class="fas fa-info-circle"></i> Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="card-body">
            <div class="alert alert-warning alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                <h5><i class="icon fas fa-exclamation-triangle"></i> Alert!</h5>
                No products found in this category.
            </div>
        </div>
    }

</div>

@section Scripts {
    <script>

            document.querySelectorAll(".js-deleted").forEach((e) => {
            e.addEventListener("click", async (event) => {
                event.preventDefault();

                const result = await Swal.fire({
                    title: "Are you sure?",
                    text: "You won't be able to revert this!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#3085d6",
                    cancelButtonColor: "#d33",
                    confirmButtonText: "Yes, delete it!"
                });

                if (result.isConfirmed) {
                    const id = e.dataset.id;

                           const response = await fetch(
            '@Url.Action("Delete", "Categories", new { area = "Admin" })/' + id,
            {
                method: "POST"
            }
        );

                    if (response.ok) {
                        e.closest("tr").remove();

                        const Toast = Swal.mixin({
                            toast: true,
                            position: "top-end",
                            showConfirmButton: false,
                            timer: 3000,
                            timerProgressBar: true
                        });

                        Toast.fire({
                            icon: "success",
                            title: "Category deleted successfully"
                        });
                    } else {
                        Swal.fire({
                            icon: "error",
                            title: "Error",
                            text: "Something went wrong."
                        });
                    }
                }
            });
        });
    </script>
}


