@model All_Baby_Essentials.Areas.Admin.ViewModels.CategoryVM

@{
    ViewData["Title"] = "Category Details";
}

<div class="category-dashboard-container mt-4" style="max-width: 1000px; margin: 0 auto;">
    
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 px-3">
        <div>
            <h2 class="mb-1" style="font-weight: 800; color: #2b3445; letter-spacing: -0.5px;">
                <i class="fas fa-info-circle text-primary mr-2" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i> 
                Category Details
            </h2>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Overview of the category and its products.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn km-btn-gradient mr-2">
                <i class="fas fa-edit mr-1"></i> Edit Category
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 10px;">
                <i class="fas fa-arrow-left mr-1"></i> Back
            </a>
        </div>
    </div>

    <!-- Category Info Card -->
    <div class="card border-0 km-card-glass shadow-lg mb-5">
        <div class="card-body p-4 p-md-5">
            <div class="row align-items-center">
                <!-- Image -->
                <div class="col-md-4 text-center mb-4 mb-md-0 border-right">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="/img/upload/@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded-lg shadow-sm" style="max-height: 220px; object-fit: contain;" />
                    }
                    else
                    {
                        <div class="rounded-lg bg-light d-flex align-items-center justify-content-center mx-auto" style="height: 200px; width: 200px; border: 2px dashed #cbd5e1;">
                            <div class="text-muted text-center">
                                <i class="fas fa-image fa-3x mb-2 opacity-50"></i>
                                <p class="mb-0 small fw-bold">No Image</p>
                            </div>
                        </div>
                    }
                </div>
                
                <!-- Details -->
                <div class="col-md-8 pl-md-5">
                    <div class="mb-2 d-flex align-items-center">
                        <span class="km-id-badge mr-3">#@Model.Id</span>
                        <h3 class="mb-0 font-weight-bold" style="color: #1e293b;">@Model.Name</h3>
                    </div>
                    
                    <p class="text-muted mb-4" style="font-size: 1.05rem; line-height: 1.6;">
                        @(string.IsNullOrEmpty(Model.Description) ? "No description provided for this category." : Model.Description)
                    </p>
                    
                    <div class="row mb-4">
                        <div class="col-sm-6 mb-3">
                            <small class="text-muted text-uppercase fw-bold" style="letter-spacing: 1px;">Created At</small>
                            <h6 class="mb-0 font-weight-bold"><i class="far fa-calendar-alt text-info mr-2"></i> @Model.CreatedAt.ToString("MMM dd, yyyy - HH:mm")</h6>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <small class="text-muted text-uppercase fw-bold" style="letter-spacing: 1px;">Last Updated</small>
                            <h6 class="mb-0 font-weight-bold"><i class="far fa-clock text-warning mr-2"></i> @Model.UpdatedAt.ToString("MMM dd, yyyy - HH:mm")</h6>
                        </div>
                    </div>
                    
                    <button type="button" class="btn btn-outline-danger btn-sm js-deleted" data-id="@Model.Id" style="border-radius: 8px;">
                        <i class="fas fa-trash-alt mr-1"></i> Delete this Category
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Associated Products Table -->
    <h4 class="font-weight-bold mb-3 pl-2"><i class="fas fa-box-open text-primary mr-2"></i> Products in this Category</h4>
    
    @if (Model.Products != null && Model.Products.Any())
    {
        <div class="card border-0 km-card-glass shadow-lg">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table km-vibrant-table mb-0">
                        <thead>
                            <tr>
                                <th>Product Name</th>
                                <th class="text-center" style="width: 150px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model.Products)
                            {
                                <tr class="km-table-row">
                                    <td class="align-middle">
                                        <div class="d-flex align-items-center">
                                            <div class="km-avatar-initial mr-3" style="width: 35px; height: 35px; font-size: 1rem; background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);">
                                                <i class="fas fa-cube"></i>
                                            </div>
                                            <h6 class="mb-0 font-weight-bold text-dark">@product.Name</h6>
                                        </div>
                                    </td>
                                    <td class="text-center align-middle">
                                        <div class="km-action-group">
                                            <a asp-area="Admin" asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="km-icon-btn km-info" title="View Product Details">
                                                <i class="fas fa-arrow-right"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white border-top-0 py-3" style="border-radius: 0 0 20px 20px;">
                <span class="text-muted font-weight-bold">Total Products: @Model.Products.Count()</span>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning rounded-lg shadow-sm border-0 d-flex align-items-center p-4">
            <i class="fas fa-box-open fa-2x mr-3 text-warning"></i>
            <div>
                <h5 class="mb-1 font-weight-bold">No Products Found</h5>
                <p class="mb-0 text-muted">This category does not contain any products yet.</p>
            </div>
        </div>
    }

</div>

@section Scripts {
    <script>
        document.querySelectorAll(".js-deleted").forEach((e) => {
            e.addEventListener("click", async (event) => {
                event.preventDefault();

                const result = await Swal.fire({
                    title: "Are you sure?",
                    text: "Deleting this category might affect associated products!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#ef4444",
                    cancelButtonColor: "#64748b",
                    confirmButtonText: "Yes, delete it!",
                    customClass: {
                        confirmButton: 'btn km-btn-gradient mr-2',
                        cancelButton: 'btn btn-secondary'
                    },
                    buttonsStyling: false
                });

                if (result.isConfirmed) {
                    const id = e.dataset.id;
                    const response = await fetch(
                        '@Url.Action("Delete", "Categories", new { area = "Admin" })/' + id,
                        { method: "POST" }
                    );

                    if (response.ok) {
                        const Toast = Swal.mixin({
                            toast: true, position: "top-end",
                            showConfirmButton: false, timer: 3000, timerProgressBar: true
                        });
                        Toast.fire({ icon: "success", title: "Category deleted successfully" }).then(() => {
                            window.location.href = '@Url.Action("Index", "Categories", new { area = "Admin" })';
                        });
                    } else {
                        Swal.fire({ icon: "error", title: "Error", text: "Something went wrong. Make sure no products are still using this category." });
                    }
                }
            });
        });
    </script>
}