@model IEnumerable<All_Baby_Essentials.Areas.Admin.ViewModels.CategoryVM>
@{
    ViewData["Title"] = "Index";
}

<div class="category-dashboard-container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 px-3">
        <div>
            <h2 class="mb-1" style="font-weight: 800; color: #2b3445; letter-spacing: -0.5px;">
                <i class="fas fa-layer-group text-primary mr-2" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i> 
                Categories Management
            </h2>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Manage, add, and organize all product categories in your store.</p>
        </div>
        <a asp-controller="Categories" asp-action="Create" class="btn km-btn-gradient">
            <i class="fas fa-plus-circle mr-1"></i> Add New Category
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning rounded-lg shadow-sm border-0 d-flex align-items-center p-4">
            <i class="fas fa-exclamation-circle fa-2x mr-3 text-warning"></i>
            <div>
                <h5 class="mb-1 font-weight-bold">No Categories Found</h5>
                <p class="mb-0 text-muted">Your store currently doesn't have any categories. Start by creating one.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 km-card-glass shadow-lg">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table km-vibrant-table mb-0">
                        <thead>
                            <tr>
                                <th style="width: 80px;" class="text-center">ID</th>
                                <th>Category Name</th>
                                <th class="text-center" style="width: 250px;">Quick Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="km-table-row">
                                    <td class="text-center align-middle">
                                        <span class="km-id-badge">#@item.Id</span>
                                    </td>
                                    <td class="align-middle">
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                                            {
                                                <img src="/img/upload/@item.ImageUrl" alt="@item.Name" class="mr-3 rounded-lg shadow-sm" style="width: 45px; height: 45px; object-fit: cover; border-radius: 12px; box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08); border: 1px solid rgba(0,0,0,0.08);" />
                                            }
                                            else
                                            {
                                                <div class="km-avatar-initial mr-3">
                                                    @item.Name.Substring(0, 1).ToUpper()
                                                </div>
                                            }
                                            <div>
                                                <h6 class="mb-0 font-weight-bold text-dark">@item.Name</h6>
                                                <small class="text-muted">Category Item</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center align-middle">
                                        <div class="km-action-group">
                                            <a asp-controller="Categories" asp-action="Details" asp-route-id="@item.Id" class="km-icon-btn km-info" title="View Details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-controller="Categories" asp-action="Edit" asp-route-id="@item.Id" class="km-icon-btn km-edit" title="Edit Category">
                                                <i class="fas fa-pen"></i>
                                            </a>
                                            <a href="#" class="km-icon-btn km-delete js-deleted" data-id="@item.Id" title="Delete Category">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<style>
    /* Card & Container */
    .km-card-glass {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05) !important;
        backdrop-filter: blur(10px);
    }
    
    /* Vibrant Table */
    .km-vibrant-table {
        border-collapse: separate;
        border-spacing: 0;
        width: 100%;
    }
    .km-vibrant-table thead {
        background: #f8f9fa;
    }
    .km-vibrant-table th {
        font-weight: 700;
        color: #8392a5;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 1.2rem 1.5rem;
        border: none;
        border-bottom: 2px solid #edf2f9;
    }
    .km-vibrant-table td {
        padding: 1.2rem 1.5rem;
        border: none;
        border-bottom: 1px solid #edf2f9;
        transition: all 0.3s ease;
    }
    
    /* Row Hover Animation */
    .km-table-row {
        transition: all 0.3s ease;
    }
    .km-table-row:hover {
        background-color: #fcfdfe;
        transform: scale(1.005);
        box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        z-index: 10;
        position: relative;
    }
    
    /* Decorative Elements */
    .km-id-badge {
        background: #f1f5f9;
        color: #64748b;
        padding: 0.3rem 0.6rem;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.85rem;
    }
    .km-avatar-initial {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        font-weight: bold;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(118, 75, 162, 0.3);
    }
    
    /* Action Buttons */
    .km-action-group {
        display: flex;
        justify-content: center;
        gap: 8px;
    }
    .km-icon-btn {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        text-decoration: none !important;
        background: white;
        border: 1px solid #e2e8f0;
    }
    .km-icon-btn.km-info { color: #0ea5e9; }
    .km-icon-btn.km-edit { color: #10b981; }
    .km-icon-btn.km-delete { color: #ef4444; }
    
    .km-icon-btn:hover {
        transform: translateY(-3px);
    }
    .km-icon-btn.km-info:hover { background: #0ea5e9; color: white; border-color: #0ea5e9; box-shadow: 0 4px 10px rgba(14, 165, 233, 0.3); }
    .km-icon-btn.km-edit:hover { background: #10b981; color: white; border-color: #10b981; box-shadow: 0 4px 10px rgba(16, 185, 129, 0.3); }
    .km-icon-btn.km-delete:hover { background: #ef4444; color: white; border-color: #ef4444; box-shadow: 0 4px 10px rgba(239, 68, 68, 0.3); }

    /* Main Button */
    .km-btn-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 0.7rem 1.5rem;
        border-radius: 12px;
        font-weight: 600;
        box-shadow: 0 6px 15px rgba(118, 75, 162, 0.3);
        transition: all 0.3s ease;
    }
    .km-btn-gradient:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(118, 75, 162, 0.4);
        color: white;
    }
</style>

@section Scripts {
    <script>
        document.querySelectorAll(".js-deleted").forEach((e) => {
            e.addEventListener("click", async (event) => {
                event.preventDefault();

                const result = await Swal.fire({
                    title: "Are you sure?",
                    text: "You won't be able to revert this!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#ef4444",
                    cancelButtonColor: "#64748b",
                    confirmButtonText: "Yes, delete it!",
                    customClass: {
                        confirmButton: 'btn km-btn-gradient mr-2',
                        cancelButton: 'btn btn-secondary'
                    },
                    buttonsStyling: false
                });

                if (result.isConfirmed) {
                    const id = e.dataset.id;
                    const response = await fetch(
                        '@Url.Action("Delete", "Categories", new { area = "Admin" })/' + id,
                        { method: "POST" }
                    );

                    if (response.ok) {
                        e.closest("tr").style.opacity = 0;
                        setTimeout(() => {
                            e.closest("tr").remove();
                        }, 300);
                        
                        const Toast = Swal.mixin({
                            toast: true,
                            position: "top-end",
                            showConfirmButton: false,
                            timer: 3000,
                            timerProgressBar: true
                        });
                        Toast.fire({
                            icon: "success",
                            title: "Category deleted successfully"
                        });
                    } else {
                        Swal.fire({
                            icon: "error",
                            title: "Error",
                            text: "Something went wrong."
                        });
                    }
                }
            });
        });
    </script>
}