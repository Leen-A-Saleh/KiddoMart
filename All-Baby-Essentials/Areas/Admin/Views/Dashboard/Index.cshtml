@model All_Baby_Essentials.Areas.Admin.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="category-dashboard-container mt-4">
    <!-- Page Title -->
    <div class="d-flex justify-content-between align-items-center mb-4 px-3">
        <div>
            <h2 class="mb-1" style="font-weight: 800; color: #2b3445; letter-spacing: -0.5px;">
                <i class="fas fa-chart-pie text-primary mr-2" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i> 
                Dashboard Overview
            </h2>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Real-time storefront metrics, recent transactions, and order trends.</p>
        </div>
    </div>

    <!-- Top Summary Cards -->
    <div class="row g-3">
        <!-- Total Users -->
        <div class="col-lg-3 col-sm-6">
            <div class="small-box bg-info">
                <div class="inner">
                    <h3>@(Model?.TotalUsers ?? 0)</h3>
                    <p>Total Users</p>
                </div>
                <div class="icon"><i class="fas fa-users"></i></div>
                <a asp-area="Admin" asp-controller="ApplicationUser" asp-action="Index" class="small-box-footer">
                    More info <i class="fas fa-arrow-circle-right"></i>
                </a>
            </div>
        </div>

        <!-- Total Products -->
        <div class="col-lg-3 col-sm-6">
            <div class="small-box bg-success">
                <div class="inner">
                    <h3>@(Model?.TotalProducts ?? 0)</h3>
                    <p>Total Products</p>
                </div>
                <div class="icon"><i class="fas fa-box"></i></div>
                <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="small-box-footer">
                    More info <i class="fas fa-arrow-circle-right"></i>
                </a>
            </div>
        </div>

        <!-- Total Categories -->
        <div class="col-lg-3 col-sm-6">
            <div class="small-box bg-warning">
                <div class="inner">
                    <h3>@(Model?.TotalCategories ?? 0)</h3>
                    <p>Total Categories</p>
                </div>
                <div class="icon"><i class="fas fa-tags"></i></div>
                <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="small-box-footer">
                    More info <i class="fas fa-arrow-circle-right"></i>
                </a>
            </div>
        </div>

        <!-- Total Orders -->
        <div class="col-lg-3 col-sm-6">
            <div class="small-box bg-danger">
                <div class="inner">
                    <h3>@(Model?.TotalOrders ?? 0)</h3>
                    <p>Total Orders</p>
                </div>
                <div class="icon"><i class="fas fa-shopping-cart"></i></div>
                <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="small-box-footer">
                    More info <i class="fas fa-arrow-circle-right"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Statistics and Chart Section -->
    <div class="row mb-5">
        <!-- Best Seller Block -->
        <div class="col-lg-4 mb-4 mb-lg-0">
            <div class="card border-0 km-card-glass shadow-lg h-100">
                <div class="card-header border-0 bg-white pt-4 pb-0">
                    <h5 class="card-title mb-0 fw-bold text-dark"><i class="fas fa-trophy text-warning mr-2"></i> Best Seller</h5>
                </div>
                <div class="card-body text-center d-flex flex-column justify-content-center py-4">
                    <div class="km-avatar-initial mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2.2rem; background: linear-gradient(135deg, #f6d365 0%, #fda085 100%); box-shadow: 0 8px 20px rgba(253, 160, 133, 0.4);">
                        <i class="fas fa-crown text-white"></i>
                    </div>
                    <h3 class="fw-bold text-primary mb-2" style="color: #fda085 !important; font-size: 2.5rem;">@Model.MostOrderedProductCount</h3>
                    <h5 class="font-weight-bold text-dark px-3 mb-1">@Model.MostOrderedProduct</h5>
                    <p class="text-muted small mb-0">Total Product Units Sold</p>
                </div>
            </div>
        </div>

        <!-- Order Trend Chart -->
        <div class="col-lg-8">
            <div class="card border-0 km-card-glass shadow-lg h-100">
                <div class="card-header border-0 bg-white pt-4 pb-0">
                    <h5 class="card-title mb-0 fw-bold text-dark"><i class="fas fa-chart-line text-primary mr-2"></i> Order Trends (Last 30 Days)</h5>
                </div>
                <div class="card-body mt-2">
                    <canvas id="ordersChart" style="min-height: 220px; height: 220px; max-height: 220px; max-width: 100%;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Orders Section -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 km-card-glass shadow-lg">
                <div class="card-header bg-white border-0 pt-4 pb-2 d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0 font-weight-bold text-dark"><i class="fas fa-receipt text-muted mr-2"></i> Latest Transactions</h5>
                    <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-xs btn-outline-primary" style="border-radius: 8px;">View All Transactions</a>
                </div>
                <div class="card-body p-0 mt-2">
                    <div class="table-responsive">
                        <table class="table km-vibrant-table mb-0">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th class="text-right">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model?.RecentOrders != null && Model.RecentOrders.Any())
                                {
                                    @foreach (var order in Model.RecentOrders)
                                    {
                                        <tr class="km-table-row">
                                            <td class="align-middle">
                                                <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id" class="font-weight-bold text-primary">#@order.Id</a>
                                            </td>
                                            <td class="align-middle">
                                                <div class="d-flex align-items-center">
                                                    <div class="km-avatar-initial mr-2" style="width: 30px; height: 30px; font-size: 0.85rem; background: #e2e8f0; color: #4a5568;">
                                                        @(string.IsNullOrWhiteSpace(order.FullName) ? "U" : order.FullName.Substring(0, 1).ToUpper())
                                                    </div>
                                                    <span class="font-weight-bold text-dark">@order.FullName</span>
                                                </div>
                                            </td>
                                            <td class="align-middle">
                                                @{
                                                    var sc = order.Status switch
                                                    {
                                                        All_Baby_Essentials.Models.OrderStatus.Completed  => "badge badge-success",
                                                        All_Baby_Essentials.Models.OrderStatus.Processing => "badge badge-warning",
                                                        All_Baby_Essentials.Models.OrderStatus.Cancelled  => "badge badge-danger",
                                                        _                                                 => "badge badge-secondary"
                                                    };
                                                }
                                                <span class="@sc text-uppercase" style="padding: 0.4rem 0.6rem; border-radius: 6px; font-size:0.75rem;">@order.Status</span>
                                            </td>
                                            <td class="align-middle text-muted">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                            <td class="align-middle text-right font-weight-bold text-dark">$@order.TotalAmount.ToString("0.00")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-5">
                                            <i class="fas fa-receipt fa-2x mb-2 opacity-50"></i>
                                            <p class="mb-0">No transactions recorded yet.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .stat-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 25px rgba(0, 0, 0, 0.1) !important;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('ordersChart').getContext('2d');
            
            const labels = @Html.Raw(Json.Serialize(Model.OrdersPerDay.Keys));
            const data = @Html.Raw(Json.Serialize(Model.OrdersPerDay.Values));

            // Create linear gradient for line chart
            const gradient = ctx.createLinearGradient(0, 0, 0, 200);
            gradient.addColorStop(0, 'rgba(79, 172, 254, 0.4)');
            gradient.addColorStop(1, 'rgba(0, 242, 254, 0.02)');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Number of Orders',
                        data: data,
                        borderColor: '#4facfe',
                        backgroundColor: gradient,
                        borderWidth: 3,
                        fill: true,
                        tension: 0.35,
                        pointRadius: 5,
                        pointBackgroundColor: '#00f2fe',
                        pointBorderColor: '#ffffff',
                        pointBorderWidth: 2,
                        pointHoverRadius: 7
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(226, 232, 240, 0.6)'
                            },
                            ticks: { 
                                stepSize: 1, 
                                precision: 0,
                                color: '#94a3b8'
                            }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#94a3b8' }
                        }
                    }
                }
            });
        });
    </script>
}