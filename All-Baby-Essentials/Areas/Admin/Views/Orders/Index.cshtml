@model IEnumerable<All_Baby_Essentials.Models.Order>

@{
    ViewData["Title"] = "Orders Management";
}

<div class="category-dashboard-container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 px-3">
        <div>
            <h2 class="mb-1" style="font-weight: 800; color: #2b3445; letter-spacing: -0.5px;">
                <i class="fas fa-shopping-cart text-primary mr-2" style="background: linear-gradient(135deg, #f6d365 0%, #fda085 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i> 
                Orders Management
            </h2>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Track, process, and manage customer orders.</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning rounded-lg shadow-sm border-0 d-flex align-items-center p-4">
            <i class="fas fa-shopping-bag fa-2x mr-3 text-warning"></i>
            <div>
                <h5 class="mb-1 font-weight-bold">No Orders Found</h5>
                <p class="mb-0 text-muted">No customer orders have been placed yet.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 km-card-glass shadow-lg">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table km-vibrant-table mb-0">
                        <thead>
                            <tr>
                                <th style="width: 80px;" class="text-center">Order ID</th>
                                <th>Customer Name</th>
                                <th>Order Date</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                                <th class="text-center" style="width: 150px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="km-table-row">
                                    <td class="text-center align-middle">
                                        <span class="km-id-badge">#@item.Id</span>
                                    </td>
                                    <td class="align-middle">
                                        <div class="d-flex align-items-center">
                                            <div class="km-avatar-initial mr-3" style="background: linear-gradient(135deg, #2af598 0%, #009efd 100%); box-shadow: 0 4px 10px rgba(42, 245, 152, 0.3);">
                                                <i class="fas fa-user"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 font-weight-bold text-dark">@item.FullName</h6>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="align-middle text-muted">@item.OrderDate.ToString("MMM dd, yyyy")</td>
                                    <td class="align-middle font-weight-bold" style="color: #009efd;">$@item.TotalAmount.ToString("0.00")</td>
                                    <td class="align-middle">
                                        @{
                                            var statusClass = item.Status switch
                                            {
                                                All_Baby_Essentials.Models.OrderStatus.Completed  => "badge badge-success",
                                                All_Baby_Essentials.Models.OrderStatus.Processing => "badge badge-warning",
                                                All_Baby_Essentials.Models.OrderStatus.Cancelled  => "badge badge-danger",
                                                _                                                 => "badge badge-secondary"
                                            };
                                        }
                                        <span class="@statusClass" style="padding: 0.4rem 0.6rem; border-radius: 6px;">@item.Status</span>
                                    </td>
                                    <td class="text-center align-middle">
                                        <div class="km-action-group">
                                            <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@item.Id" class="km-icon-btn km-info" title="View Details" style="width: auto; padding: 0 1rem; border-radius: 8px;">
                                                <i class="fas fa-eye mr-2"></i> View
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>