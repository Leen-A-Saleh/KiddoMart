@model All_Baby_Essentials.Models.Order

@{
    ViewData["Title"] = "Order Details";
}

<div class="container-fluid py-4">
    <div class="row">
        <!-- Order Info -->
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header pb-0">
                    <h6>Order #@Model.Id Details</h6>
                </div>
                <div class="card-body">
                    <p><strong>Customer:</strong> @Model.FullName</p>
                    <p><strong>Email:</strong> @Model.User?.Email</p>
                    <p><strong>Phone:</strong> @Model.PhoneNumber</p>
                    <p><strong>Date:</strong> @Model.OrderDate.ToString("g")</p>
                    <p><strong>Address:</strong> @Model.ShippingAddress</p>
                    <p><strong>Total:</strong> $@Model.TotalAmount.ToString("0.00")</p>
                    <p><strong>Payment Status:</strong> @Model.PaymentStatus</p>

                    <h6 class="mt-4">Items</h6>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Price</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td>@item.Product.Name</td>
                                    <td>@item.Quantity</td>
                                    <td>$@item.UnitPrice.ToString("0.00")</td>
                                    <td>$@((item.Quantity * item.UnitPrice).ToString("0.00"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <!-- Update Status -->
        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header pb-0">
                    <h6>Update Status</h6>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label">Order Status</label>
                            <select name="status" class="form-select" asp-for="Status" asp-items="Html.GetEnumSelectList<All_Baby_Essentials.Models.OrderStatus>()"></select>
                        </div>
                        <button type="submit" class="btn bg-gradient-primary w-100">Update Status</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
