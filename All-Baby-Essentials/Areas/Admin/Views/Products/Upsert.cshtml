@model All_Baby_Essentials.Areas.Admin.ViewModels.ProductFormVM

@{
    ViewData["Title"] = Model?.Id == 0 ? "Create Product" : "Edit Product";
}

<div class="category-dashboard-container mt-4" style="max-width: 900px; margin: 0 auto;">
    <div class="d-flex justify-content-between align-items-center mb-4 px-3">
        <div>
            <h2 class="mb-1" style="font-weight: 800; color: #2b3445; letter-spacing: -0.5px;">
                <i class="fas @(Model?.Id == 0 ? "fa-plus-circle" : "fa-edit") text-primary mr-2" style="background: linear-gradient(135deg, #f6d365 0%, #fda085 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i> 
                @(Model?.Id == 0 ? "Create New Product" : "Edit Product")
            </h2>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">
                @(Model?.Id == 0 ? "Add a new product to your inventory." : "Update the details of the existing product.")
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 10px;">
            <i class="fas fa-arrow-left mr-1"></i> Back to List
        </a>
    </div>

    <div class="card border-0 km-card-glass shadow-lg">
        <div class="card-body p-4 p-md-5">
            <form class="form-horizontal" asp-area="Admin" asp-controller="Products" asp-action="@(Model?.Id == 0 ? "Create" : "Edit")" enctype="multipart/form-data" method="post">
                @Html.AntiForgeryToken()
                
                @if (Model?.Id != 0)
                {
                    <input type="hidden" asp-for="Id" />
                }

                <div class="row">
                    <!-- Name & Category -->
                    <div class="col-md-6 mb-4">
                        <label asp-for="Name" class="form-label font-weight-bold text-dark">Product Name <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-white border-right-0"><i class="fas fa-box text-muted"></i></span>
                            </div>
                            <input type="text" asp-for="Name" class="form-control border-left-0 km-input" placeholder="e.g. Baby Stroller" style="box-shadow:none;" />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="CategoryId" class="form-label font-weight-bold text-dark">Category <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-white border-right-0"><i class="fas fa-layer-group text-muted"></i></span>
                            </div>
                            <select asp-for="CategoryId" asp-items="Model.Categories" class="form-control border-left-0 km-input" style="box-shadow:none;">
                                <option value="">-- Select Category --</option>
                            </select>
                        </div>
                        <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Price & Discount -->
                    <div class="col-md-6 mb-4">
                        <label asp-for="Price" class="form-label font-weight-bold text-dark">Price ($) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-white border-right-0"><i class="fas fa-dollar-sign text-muted"></i></span>
                            </div>
                            <input type="number" asp-for="Price" class="form-control border-left-0 km-input" placeholder="0.00" step="0.01" min="0.5" style="box-shadow:none;" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="DiscountPercentage" class="form-label font-weight-bold text-dark">Discount (%)</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-white border-right-0"><i class="fas fa-percent text-muted"></i></span>
                            </div>
                            <input type="number" asp-for="DiscountPercentage" class="form-control border-left-0 km-input" placeholder="e.g. 20" step="0.1" min="0" max="100" style="box-shadow:none;" />
                        </div>
                        <span asp-validation-for="DiscountPercentage" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Description" class="form-label font-weight-bold text-dark">Description</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-white border-right-0 align-items-start pt-2"><i class="fas fa-align-left text-muted"></i></span>
                        </div>
                        <textarea asp-for="Description" class="form-control border-left-0 km-input" rows="4" placeholder="Briefly describe this product..." style="box-shadow:none;"></textarea>
                    </div>
                    <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="form-group mb-5">
                    <label class="form-label font-weight-bold text-dark">Product Images</label>
                    <div class="custom-file-upload border rounded p-4 text-center bg-light" style="border: 2px dashed #cbd5e1 !important; border-radius: 12px !important; transition: all 0.3s ease;">
                        <input type="file" name="ImageFiles" id="ImageFiles" class="d-none" accept="image/*" multiple onchange="previewImages(event)" />
                        
                        <div id="uploadPrompt">
                            <i class="fas fa-images fa-3x text-muted mb-3"></i>
                            <h6 class="mb-1 font-weight-bold">Upload Images</h6>
                            <p class="text-muted small mb-3">Select multiple images (PNG, JPG, WEBP). First image will be main.</p>
                            <label for="ImageFiles" class="btn btn-outline-primary btn-sm px-4" style="border-radius: 8px; cursor: pointer;">Browse Files</label>
                        </div>
                        
                        <div id="imagePreviews" class="d-flex flex-wrap justify-content-center gap-3 mt-3"></div>
                    </div>
                </div>

                <hr class="mb-4" />

                <div class="d-flex justify-content-end gap-3">
                    <button type="submit" class="btn km-btn-gradient px-5 py-2" style="font-size: 1.1rem; background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);">
                        <i class="fas @(Model?.Id == 0 ? "fa-check-circle" : "fa-save") mr-2"></i> @(Model?.Id == 0 ? "Create Product" : "Save Changes")
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .km-input:focus {
        border-color: #fda085;
        box-shadow: none;
    }
    .input-group-text {
        border-radius: 10px 0 0 10px;
    }
    .km-input {
        border-radius: 0 10px 10px 0;
    }
    .custom-file-upload:hover {
        background-color: #fffaf0 !important;
        border-color: #fda085 !important;
    }
    .image-preview-wrapper {
        position: relative;
        display: inline-block;
    }
    .main-badge {
        position: absolute;
        top: -10px;
        right: -10px;
        background: #f43f5e;
        color: white;
        font-size: 0.7rem;
        font-weight: bold;
        padding: 3px 8px;
        border-radius: 10px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function previewImages(event) {
            const input = event.target;
            const container = document.getElementById('imagePreviews');
            const prompt = document.getElementById('uploadPrompt');
            
            container.innerHTML = '';

            if (input.files && input.files.length > 0) {
                Array.from(input.files).forEach((file, index) => {
                    const wrapper = document.createElement('div');
                    wrapper.classList.add('image-preview-wrapper');

                    const img = document.createElement('img');
                    img.src = URL.createObjectURL(file);
                    img.alt = file.name;
                    img.classList.add('img-thumbnail', 'shadow-sm', 'rounded');
                    img.style.width = '100px';
                    img.style.height = '100px';
                    img.style.objectFit = 'cover';
                    wrapper.appendChild(img);

                    if (index === 0) {
                        const badge = document.createElement('div');
                        badge.classList.add('main-badge');
                        badge.innerHTML = 'MAIN';
                        wrapper.appendChild(badge);
                    }

                    container.appendChild(wrapper);
                });
            }
        }
    </script>
}