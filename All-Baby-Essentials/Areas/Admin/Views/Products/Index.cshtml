@model IEnumerable<All_Baby_Essentials.Areas.Admin.ViewModels.ProductDetailsVM>
@{
    ViewData["Title"] = "Index";
}

<div class="category-dashboard-container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 px-3">
        <div>
            <h2 class="mb-1" style="font-weight: 800; color: #2b3445; letter-spacing: -0.5px;">
                <i class="fas fa-box-open text-primary mr-2" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i> 
                Products Management
            </h2>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Manage your inventory, prices, and product details.</p>
        </div>
        <a asp-controller="Products" asp-action="Create" class="btn km-btn-gradient">
            <i class="fas fa-plus-circle mr-1"></i> Add New Product
        </a>
    </div>

    <!-- Filters -->
    <div class="card border-0 km-card-glass shadow-sm mb-4">
        <div class="card-body p-3">
            <form method="get" asp-action="Index" class="row g-3 align-items-center m-0">
                <div class="col-md-4">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-white border-right-0"><i class="fas fa-search text-muted"></i></span>
                        </div>
                        <input type="text" name="search" value="@ViewBag.Search" class="form-control border-left-0" placeholder="Search products by name..." style="box-shadow:none;" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="colorId" class="form-control w-100" style="box-shadow:none;">
                        <option value="">-- Filter by Color --</option>
                        @if (ViewBag.ColorsList != null)
                        {
                            foreach (var opt in ViewBag.ColorsList as List<SelectListItem>)
                            {
                                if (opt.Selected)
                                {
                                    <option value="@opt.Value" selected="selected">@opt.Text</option>
                                }
                                else
                                {
                                    <option value="@opt.Value">@opt.Text</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="stockFilter" class="form-control w-100" style="box-shadow:none;">
                        <option value="">-- Filter by Stock --</option>
                        @if (ViewBag.StockFilter == "out")
                        {
                            <option value="out" selected="selected">Out of Stock</option>
                        }
                        else
                        {
                            <option value="out">Out of Stock</option>
                        }
                        @if (ViewBag.StockFilter == "low")
                        {
                            <option value="low" selected="selected">Low Stock (&lt; 10)</option>
                        }
                        else
                        {
                            <option value="low">Low Stock (&lt; 10)</option>
                        }
                        @if (ViewBag.StockFilter == "instock")
                        {
                            <option value="instock" selected="selected">In Stock (&gt;= 10)</option>
                        }
                        else
                        {
                            <option value="instock">In Stock (&gt;= 10)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn km-btn-gradient w-100"><i class="fas fa-filter"></i> Filter</button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning rounded-lg shadow-sm border-0 d-flex align-items-center p-4">
            <i class="fas fa-exclamation-circle fa-2x mr-3 text-warning"></i>
            <div>
                <h5 class="mb-1 font-weight-bold">No Products Found</h5>
                <p class="mb-0 text-muted">No products match your search criteria. Try adjusting the filters or add a new product.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 km-card-glass shadow-lg">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table km-vibrant-table mb-0">
                        <thead>
                            <tr>
                                <th style="width: 80px;" class="text-center">ID</th>
                                <th>Name & Category</th>
                                <th>Price</th>
                                <th>Discount</th>
                                <th>Stock</th>
                                <th class="text-center" style="width: 250px;">Quick Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="km-table-row">
                                    <td class="text-center align-middle">
                                        <span class="km-id-badge">#@item.Id</span>
                                    </td>
                                    <td class="align-middle">
                                        <div class="d-flex align-items-center">
                                            <div class="km-avatar-initial mr-3" style="background: linear-gradient(135deg, #f6d365 0%, #fda085 100%); box-shadow: 0 4px 10px rgba(253, 160, 133, 0.3);">
                                                <i class="fas fa-cube"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 font-weight-bold text-dark">@item.Name</h6>
                                                <small class="text-muted"><i class="fas fa-tag mr-1"></i> @item.CategoryName</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="align-middle font-weight-bold" style="color: #4facfe;">@item.Price.ToString("C")</td>
                                    <td class="align-middle">
                                        @if (item.DiscountPercentage.HasValue && item.DiscountPercentage.Value > 0)
                                        {
                                            <span class="badge badge-danger" style="padding: 0.4rem 0.6rem; border-radius: 6px;">@item.DiscountPercentage.Value.ToString("0")% OFF</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="align-middle">
                                        @if (item.StockQuantity == 0)
                                        {
                                            <span class="badge badge-danger" style="padding: 0.4rem 0.6rem; border-radius: 6px;">Out of Stock</span>
                                        }
                                        else if (item.StockQuantity < 10)
                                        {
                                            <span class="badge badge-warning" style="padding: 0.4rem 0.6rem; border-radius: 6px;">@item.StockQuantity Left</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-success" style="padding: 0.4rem 0.6rem; border-radius: 6px;">@item.StockQuantity in Stock</span>
                                        }
                                    </td>
                                    <td class="text-center align-middle">
                                        <div class="km-action-group">
                                            <a asp-area="Admin" asp-controller="ProductColors" asp-action="Index" asp-route-productId="@item.Id" class="km-icon-btn km-info" title="Manage Colors" style="color:#8b5cf6;">
                                                <i class="fas fa-palette"></i>
                                            </a>
                                            <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id" class="km-icon-btn km-info" title="View Details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-controller="Products" asp-action="Edit" asp-route-id="@item.Id" class="km-icon-btn km-edit" title="Edit Product">
                                                <i class="fas fa-pen"></i>
                                            </a>
                                            <a href="#" class="km-icon-btn km-delete js-deleted" data-id="@item.Id" title="Delete Product">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".js-deleted").forEach((e) => {
            e.addEventListener("click", async (event) => {
                event.preventDefault();

                const result = await Swal.fire({
                    title: "Are you sure?",
                    text: "You won't be able to revert this!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#ef4444",
                    cancelButtonColor: "#64748b",
                    confirmButtonText: "Yes, delete it!",
                    customClass: {
                        confirmButton: 'btn km-btn-gradient mr-2',
                        cancelButton: 'btn btn-secondary'
                    },
                    buttonsStyling: false
                });

                if (result.isConfirmed) {
                    const id = e.dataset.id;
                    const response = await fetch(
                        '@Url.Action("Delete", "Products", new { area = "Admin" })/' + id,
                        { method: "POST" }
                    );

                    if (response.ok) {
                        e.closest("tr").style.opacity = 0;
                        setTimeout(() => {
                            e.closest("tr").remove();
                        }, 300);
                        
                        const Toast = Swal.mixin({
                            toast: true,
                            position: "top-end",
                            showConfirmButton: false,
                            timer: 3000,
                            timerProgressBar: true
                        });
                        Toast.fire({
                            icon: "success",
                            title: "Product deleted successfully"
                        });
                    } else {
                        Swal.fire({
                            icon: "error",
                            title: "Error",
                            text: "Something went wrong."
                        });
                    }
                }
            });
        });
    </script>
}