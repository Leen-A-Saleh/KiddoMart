@model All_Baby_Essentials.Areas.Admin.ViewModels.ProductDetailsVM

@{
    ViewData["Title"] = "Product Details";
}

<div class="category-dashboard-container mt-4" style="max-width: 1100px; margin: 0 auto;">
    
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 px-3">
        <div>
            <h2 class="mb-1" style="font-weight: 800; color: #2b3445; letter-spacing: -0.5px;">
                <i class="fas fa-info-circle text-primary mr-2" style="background: linear-gradient(135deg, #f6d365 0%, #fda085 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i> 
                Product Details
            </h2>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Full overview, images, color variants, and reviews for this product.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@Model.Id" class="btn km-btn-gradient mr-2" style="background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);">
                <i class="fas fa-edit mr-1"></i> Edit Product
            </a>
            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 10px;">
                <i class="fas fa-arrow-left mr-1"></i> Back
            </a>
        </div>
    </div>

    <!-- Product Summary Showcase Card -->
    <div class="card border-0 km-card-glass shadow-lg mb-5">
        <div class="card-body p-4 p-md-5">
            <div class="row align-items-start">
                <!-- Product Primary Info -->
                <div class="col-lg-7 pr-lg-5 mb-4 mb-lg-0">
                    <div class="mb-3 d-flex align-items-center flex-wrap gap-2">
                        <span class="km-id-badge mr-2">#@Model.Id</span>
                        <span class="badge badge-info mr-2" style="padding: 0.4rem 0.6rem; border-radius: 6px; font-size:0.85rem;"><i class="fas fa-tag mr-1"></i> @Model.CategoryName</span>
                        @if (Model.StockQuantity == 0)
                        {
                            <span class="badge badge-danger" style="padding: 0.4rem 0.6rem; border-radius: 6px; font-size:0.85rem;">Out of Stock</span>
                        }
                        else if (Model.StockQuantity < 10)
                        {
                            <span class="badge badge-warning" style="padding: 0.4rem 0.6rem; border-radius: 6px; font-size:0.85rem;">Low Stock (@Model.StockQuantity)</span>
                        }
                        else
                        {
                            <span class="badge badge-success" style="padding: 0.4rem 0.6rem; border-radius: 6px; font-size:0.85rem;">In Stock (@Model.StockQuantity)</span>
                        }
                    </div>

                    <h3 class="mb-3 font-weight-bold text-dark" style="font-size: 2rem;">@Model.Name</h3>
                    
                    <div class="d-flex align-items-baseline mb-4">
                        <span class="h3 font-weight-bold text-primary mb-0 mr-3" style="color: #fda085 !important;">@Model.Price.ToString("C")</span>
                        @if (Model.DiscountPercentage.HasValue && Model.DiscountPercentage.Value > 0)
                        {
                            <span class="badge badge-danger text-uppercase font-weight-bold" style="padding: 0.4rem 0.6rem; border-radius: 6px;">@Model.DiscountPercentage.Value.ToString("0")% OFF</span>
                        }
                    </div>

                    <h5 class="font-weight-bold text-dark mb-2">Description</h5>
                    <p class="text-muted" style="line-height: 1.7; font-size: 1rem;">
                        @(string.IsNullOrWhiteSpace(Model.Description) ? "No description available for this product." : Model.Description)
                    </p>

                    <div class="row mt-4 pt-3 border-top">
                        <div class="col-6">
                            <small class="text-muted text-uppercase font-weight-bold" style="letter-spacing: 0.5px;">Created On</small>
                            <p class="mb-0 font-weight-bold text-dark"><i class="far fa-calendar-alt text-info mr-1"></i> @Model.CreatedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="col-6">
                            <small class="text-muted text-uppercase font-weight-bold" style="letter-spacing: 0.5px;">Last Updated</small>
                            <p class="mb-0 font-weight-bold text-dark"><i class="far fa-clock text-warning mr-1"></i> @Model.UpdatedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>

                    <div class="mt-4 pt-3">
                        <button type="button" class="btn btn-outline-danger btn-sm js-deleted" data-id="@Model.Id" style="border-radius: 8px;">
                            <i class="fas fa-trash-alt mr-1"></i> Delete Product
                        </button>
                    </div>
                </div>

                <!-- Product Mini Image Gallery / Showcase (Main Image) -->
                <div class="col-lg-5 text-center">
                    <div class="border rounded-xl p-3 bg-light d-flex align-items-center justify-content-center mb-3" style="min-height: 300px; border-radius: 16px;">
                        @if (Model.Images.Any())
                        {
                            var mainImg = Model.Images.FirstOrDefault(i => i.IsMain) ?? Model.Images.First();
                            <img src="/img/upload/@mainImg.ImageUrl" alt="@Model.Name" id="mainProductView" class="img-fluid rounded-lg" style="max-height: 280px; object-fit: contain;" />
                        }
                        else
                        {
                            <div class="text-muted">
                                <i class="fas fa-image fa-4x mb-2 opacity-30"></i>
                                <p class="mb-0 small font-weight-bold">No Image Available</p>
                            </div>
                        }
                    </div>

                    @if (Model.Images.Count() > 1)
                    {
                        <div class="d-flex flex-wrap justify-content-center gap-2">
                            @foreach (var img in Model.Images)
                            {
                                <img src="/img/upload/@img.ImageUrl" alt="Thumbnail" class="img-thumbnail rounded cursor-pointer mini-thumb" style="width: 60px; height: 60px; object-fit: cover; cursor: pointer; transition: all 0.2s;" onclick="changeMainView(this.src)" />
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Product Colors & Stock -->
    <div class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="font-weight-bold mb-0 pl-2"><i class="fas fa-palette text-primary mr-2"></i> Color Variants & Inventory</h4>
            <a asp-area="Admin" asp-controller="ProductColors" asp-action="Index" asp-route-productId="@Model.Id" class="btn btn-sm btn-outline-primary" style="border-radius: 8px;">
                <i class="fas fa-palette mr-1"></i> Manage Colors
            </a>
        </div>

        <div class="card border-0 km-card-glass shadow-lg">
            <div class="card-body p-4">
                @if (Model.ProductColors.Any())
                {
                    <div class="row">
                        @foreach (var pc in Model.ProductColors)
                        {
                            <div class="col-md-4 col-sm-6 mb-3">
                                <div class="p-3 border rounded-lg d-flex align-items-center bg-light" style="border-radius: 12px !important;">
                                    <div class="rounded-circle border shadow-sm mr-3" style="width: 36px; height: 36px; background-color: @pc.ColorHexCode; flex-shrink: 0;"></div>
                                    <div>
                                        <h6 class="mb-0 font-weight-bold text-dark">@pc.ColorName</h6>
                                        <small class="text-muted">Stock Quantity: <strong class="text-primary">@pc.StockQuantity</strong></small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center p-3 text-muted">
                        <i class="fas fa-info-circle fa-2x mb-2 opacity-50"></i>
                        <p class="mb-0">No custom color variants defined. Using main product stock quantity (@Model.StockQuantity) instead.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Product Reviews -->
    <div class="mb-4">
        <h4 class="font-weight-bold mb-3 pl-2"><i class="fas fa-comments text-primary mr-2"></i> Customer Reviews</h4>
        
        @if (Model.Reviews.Any())
        {
            <div class="card border-0 km-card-glass shadow-lg">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table km-vibrant-table mb-0">
                            <thead>
                                <tr>
                                    <th>Customer</th>
                                    <th style="width: 140px;">Rating</th>
                                    <th>Comment</th>
                                    <th style="width: 180px;">Review Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var review in Model.Reviews)
                                {
                                    <tr class="km-table-row">
                                        <td class="align-middle font-weight-bold text-dark">@review.UserName</td>
                                        <td class="align-middle">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= review.Rating)
                                                {
                                                    <i class="fas fa-star text-warning" style="font-size:0.9rem;"></i>
                                                }
                                                else
                                                {
                                                    <i class="far fa-star text-warning" style="font-size:0.9rem;"></i>
                                                }
                                            }
                                        </td>
                                        <td class="align-middle text-muted" style="max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@review.Comment">@review.Comment</td>
                                        <td class="align-middle text-muted">@review.CreatedAt.ToString("MMM dd, yyyy - HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning rounded-lg shadow-sm border-0 d-flex align-items-center p-4">
                <i class="fas fa-comment-slash fa-2x mr-3 text-warning"></i>
                <div>
                    <h5 class="mb-1 font-weight-bold">No Reviews Yet</h5>
                    <p class="mb-0 text-muted">This product has not received any reviews from customers.</p>
                </div>
            </div>
        }
    </div>

</div>

<style>
    .mini-thumb:hover {
        border-color: #fda085 !important;
        transform: translateY(-2px);
    }
    .mini-thumb {
        border-radius: 8px;
    }
</style>

@section Scripts {
    <script>
        function changeMainView(src) {
            document.getElementById('mainProductView').src = src;
        }

        document.querySelectorAll(".js-deleted").forEach((e) => {
            e.addEventListener("click", async (event) => {
                event.preventDefault();

                const result = await Swal.fire({
                    title: "Are you sure?",
                    text: "This product and all its color variants will be permanently deleted!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#ef4444",
                    cancelButtonColor: "#64748b",
                    confirmButtonText: "Yes, delete it!",
                    customClass: {
                        confirmButton: 'btn km-btn-gradient mr-2',
                        cancelButton: 'btn btn-secondary'
                    },
                    buttonsStyling: false
                });

                if (result.isConfirmed) {
                    const id = e.dataset.id;
                    const response = await fetch(
                        '@Url.Action("Delete", "Products", new { area = "Admin" })/' + id,
                        { method: "POST" }
                    );

                    if (response.ok) {
                        const Toast = Swal.mixin({
                            toast: true, position: "top-end",
                            showConfirmButton: false, timer: 3000, timerProgressBar: true
                        });
                        Toast.fire({ icon: "success", title: "Product deleted successfully" }).then(() => {
                            window.location.href = '@Url.Action("Index", "Products", new { area = "Admin" })';
                        });
                    } else {
                        Swal.fire({ icon: "error", title: "Error", text: "Something went wrong." });
                    }
                }
            });
        });
    </script>
}