@model All_Baby_Essentials.Areas.Admin.ViewModels.ProductDetailsVM

@{
    ViewData["Title"] = "Details";
}

@* @section Title {
        Products
} *@

@section SubTitle {
        Details of @Model.Name
}

<div class="card-body">

    <!-- Product Main Information -->
    <table class="table table-bordered">
        <thead>
            <tr>
                <th style="width: 10px">#</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Discount (%)</th>
                <th>Stock</th>
                <th>Created At</th>
                <th>Updated At</th>
                <th style="width: 150px">Action</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>@Model.Id</td>
                <td>@Model.Name</td>
                <td>@Model.CategoryName</td>
                <td>@Model.Price.ToString("C")</td>
                <td>
                    @if (Model.DiscountPercentage.HasValue && Model.DiscountPercentage.Value > 0)
                    {
                        <span class="badge badge-danger">@Model.DiscountPercentage.Value.ToString("0")%</span>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
                <td>
                    @if (Model.StockQuantity == 0)
                    {
                        <span class="badge badge-danger">Out of Stock</span>
                    }
                    else if (Model.StockQuantity < 10)
                    {
                        <span class="badge badge-warning">@Model.StockQuantity</span>
                    }
                    else
                    {
                        <span class="badge badge-success">@Model.StockQuantity</span>
                    }
                </td>
                <td>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>@Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>
                    <a asp-area="Admin"
                       asp-controller="Products"
                       asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-sm btn-primary mb-1">
                        <i class="fas fa-edit"></i> Edit
                    </a>

                    <a href="#"
                       class="btn btn-sm btn-danger js-deleted"
                       data-id="@Model.Id">
                        <i class="fas fa-trash"></i> Delete
                    </a>
                </td>
            </tr>

            <!-- Colors & Inventory Row -->
            <tr>
                <th colspan="2">Colors & Inventory</th>
                <td colspan="7">
                    <div class="d-flex flex-wrap align-items-center mb-3">
                        <a asp-area="Admin" asp-controller="ProductColors" asp-action="Index" asp-route-productId="@Model.Id" class="btn btn-sm btn-info text-white" style="margin-right:15px;">
                            <i class="fas fa-palette"></i> Manage Colors & Stock
                        </a>
                    </div>
                    @if (Model.ProductColors.Any())
                    {
                        <div class="row">
                            @foreach (var pc in Model.ProductColors)
                            {
                                <div class="col-md-3 mb-2" style="margin-right:10px; display:inline-block;">
                                    <div class="p-2 border rounded d-flex align-items-center bg-light" style="display:flex; align-items:center;">
                                        <div class="rounded-circle border border-2 shadow-sm" style="width: 24px; height: 24px; background-color: @pc.ColorHexCode; margin-right:8px; flex-shrink:0;"></div>
                                        <div>
                                            <span class="fw-bold">@pc.ColorName</span>
                                            <span class="small text-muted d-block">Stock: @pc.StockQuantity</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <span class="text-muted">No custom color variants defined. Using main product stock quantity (@Model.StockQuantity) instead.</span>
                    }
                </td>
            </tr>

            <!-- Description Row -->
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <tr>
                    <th colspan="2">Description</th>
                    <td colspan="7">
                        @Model.Description
                    </td>
                </tr>
            }

            <!-- Images Row -->
            <tr>
                <th colspan="2">Images</th>
                <td colspan="7">
                    @if (Model.Images.Any())
                    {
                        <div class="d-flex flex-wrap">
                            @foreach (var image in Model.Images.OrderBy(i => i.DisplayOrder))
                            {
                                <div class="text-center mr-3 mb-3">
                                    <img src="@Url.Content("~/img/" + image.ImageUrl)"
                                         alt="@Model.Name"
                                         class="img-thumbnail"
                                         style="width:150px; height:150px; object-fit:cover;" />

                                    @if (image.IsMain)
                                    {
                                        <div class="mt-1">
                                            <span class="badge badge-primary">Main</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <span class="text-muted">No images uploaded for this product.</span>
                    }
                </td>
            </tr>

            <!-- Reviews Row -->
            <tr>
                <th colspan="2">Reviews</th>
                <td colspan="7">
                    @if (Model.Reviews.Any())
                    {
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="thead-light">
                                <tr>
                                    <th>User</th>
                                    <th style="width:120px;">Rating</th>
                                    <th>Comment</th>
                                    <th style="width:160px;">Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var review in Model.Reviews)
                                {
                                    <tr>
                                        <td>@review.UserName</td>
                                        <td>
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= review.Rating)
                                                {
                                                    <i class="fas fa-star text-warning"></i>
                                                }
                                                else
                                                {
                                                    <i class="far fa-star text-warning"></i>
                                                }
                                            }
                                        </td>
                                        <td>@review.Comment</td>
                                        <td>@review.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <span class="text-muted">No reviews found for this product.</span>
                    }
                </td>
            </tr>
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".js-deleted").forEach((e) => {
            e.addEventListener("click", async (event) => {
                event.preventDefault();

                const result = await Swal.fire({
                    title: "Are you sure?",
                    text: "You won't be able to revert this!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#3085d6",
                    cancelButtonColor: "#d33",
                    confirmButtonText: "Yes, delete it!"
                });

                if (result.isConfirmed) {
                    const id = e.dataset.id;

                    const response = await fetch(
                        '@Url.Action("Delete", "Products", new { area = "Admin" })/' + id,
                        { method: "POST" }
                    );

                    if (response.ok) {
                        window.location.href =
                            '@Url.Action("Index", "Products", new { area = "Admin" })';
                    } else {
                        Swal.fire({
                            icon: "error",
                            title: "Error",
                            text: "Something went wrong."
                        });
                    }
                }
            });
        });
    </script>
}
