@using Microsoft.AspNetCore.Identity
@using All_Baby_Essentials.Models
@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
    var adminDisplayName = currentUser?.FullName ?? currentUser?.UserName ?? "Admin";
    var adminInitials = "";
    if (!string.IsNullOrWhiteSpace(currentUser?.FullName))
    {
        adminInitials = string.Concat(
            currentUser.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Take(2).Select(word => char.ToUpper(word[0]))
        );
    }
    else if (!string.IsNullOrWhiteSpace(currentUser?.UserName))
    {
        adminInitials = currentUser.UserName.Substring(0, 1).ToUpper();
    }
    else
    {
        adminInitials = "A";
    }

    // Helper to determine if a nav item is active
    var area       = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action     = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string NavClass(string ctrl, string act = "")
    {
        bool match = string.Equals(controller, ctrl, StringComparison.OrdinalIgnoreCase)
                  && (string.IsNullOrEmpty(act) || string.Equals(action, act, StringComparison.OrdinalIgnoreCase));
        return match ? "km-nav-link active" : "km-nav-link";
    }
    string NavClassGroup(params string[] controllers)
    {
        bool match = controllers.Any(c => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase));
        return match ? "km-nav-link open" : "km-nav-link";
    }
    bool IsGroupOpen(params string[] controllers)
        => controllers.Any(c => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase));
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>KiddoMart Admin — @ViewData["Title"]</title>

    <!-- Google Fonts: DM Sans + Playfair Display -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Playfair+Display:wght@600&display=swap" rel="stylesheet">

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="~/Dashboard/plugins/fontawesome-free/css/all.min.css">
    <!-- AdminLTE Theme style -->
    <link rel="stylesheet" href="~/Dashboard/dist/css/adminlte.min.css">
    <!-- Sweet Alert -->
    <link rel="stylesheet" href="~/Dashboard/plugins/sweetalert2-theme-bootstrap-4/bootstrap-4.min.css">
    <!-- Toastr CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!--custom css-->
    <link rel="stylesheet" href="~/Dashboard/dist/css/main.css" />
</head>
<body>

    <!-- ═══ SIDEBAR ═══ -->
    <aside class="km-sidebar" id="kmSidebar">

        <!-- Brand -->
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="km-brand">
            <div class="km-brand-img w-100">
                <img src="~/img/KiddoMart.png" alt="KiddoMart Logo" class="img-fluid object-fit-contain w-100 h-100" />
            </div>
        </a>

        <!-- User panel -->
        <div class="km-user-panel">
            <div class="km-user-info">
                <div class="km-user-name">@adminDisplayName</div>
                <div class="km-user-role">Administrator</div>
            </div>
        </div>

        <!-- Nav -->
        <nav class="km-nav" aria-label="Admin navigation">

            <div class="km-nav-label">Overview</div>

            <div class="km-nav-item">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                   class="@NavClass("Dashboard")">
                    <span class="km-nav-icon"><i class="fas fa-th-large"></i></span>
                    <span class="km-nav-text">Dashboard</span>
                </a>
            </div>

            <div class="km-nav-label">Catalog</div>

            <div class="km-nav-item">
                <a href="#" class="@NavClassGroup("Categories")"
                   onclick="toggleMenu(this, 'catMenu')">
                    <span class="km-nav-icon"><i class="fas fa-tags"></i></span>
                    <span class="km-nav-text">Categories</span>
                    <i class="fas fa-chevron-down km-chevron"></i>
                </a>
                <div class="km-submenu @(IsGroupOpen("Categories") ? "open" : "")" id="catMenu">
                    <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="km-submenu-link">
                        <span class="km-submenu-dot"></span> All Categories
                    </a>
                    <a asp-area="Admin" asp-controller="Categories" asp-action="Create" class="km-submenu-link">
                        <span class="km-submenu-dot"></span> Add Category
                    </a>
                </div>
            </div>

            <div class="km-nav-item">
                <a href="#" class="@NavClassGroup("Products")"
                   onclick="toggleMenu(this, 'prodMenu')">
                    <span class="km-nav-icon"><i class="fas fa-box-open"></i></span>
                    <span class="km-nav-text">Products</span>
                    <i class="fas fa-chevron-down km-chevron"></i>
                </a>
                <div class="km-submenu @(IsGroupOpen("Products") ? "open" : "")" id="prodMenu">
                    <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="km-submenu-link">
                        <span class="km-submenu-dot"></span> All Products
                    </a>
                    <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="km-submenu-link">
                        <span class="km-submenu-dot"></span> Add Product
                    </a>
                </div>
            </div>

            <div class="km-nav-label">Management</div>

            <div class="km-nav-item">
                <a asp-area="Admin" asp-controller="Orders" asp-action="Index"
                   class="@NavClass("Orders")">
                    <span class="km-nav-icon"><i class="fas fa-shopping-bag"></i></span>
                    <span class="km-nav-text">Orders</span>
                </a>
            </div>

            <div class="km-nav-item">
                <a asp-area="Admin" asp-controller="ApplicationUser" asp-action="Index"
                   class="@NavClass("ApplicationUser")">
                    <span class="km-nav-icon"><i class="fas fa-users"></i></span>
                    <span class="km-nav-text">Users</span>
                </a>
            </div>

            <div class="km-nav-label">Content</div>

            <div class="km-nav-item">
                <a href="#" class="@NavClassGroup("Reviews")"
                   onclick="toggleMenu(this, 'reviewMenu')">
                    <span class="km-nav-icon"><i class="fas fa-star"></i></span>
                    <span class="km-nav-text">Reviews</span>
                    <i class="fas fa-chevron-down km-chevron"></i>
                </a>
                <div class="km-submenu @(IsGroupOpen("Reviews") ? "open" : "")" id="reviewMenu">
                    <a asp-area="Admin" asp-controller="Reviews" asp-action="Index" class="km-submenu-link">
                        <span class="km-submenu-dot"></span> Product Reviews
                    </a>
                    <a asp-area="Admin" asp-controller="Reviews" asp-action="Testimonials" class="km-submenu-link">
                        <span class="km-submenu-dot"></span> Testimonials
                    </a>
                </div>
            </div>

        </nav>

        <!-- Footer -->
        <div class="km-sidebar-footer">
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="mb-2">
                <i class="fas fa-store" style="font-size:16px; width:20px; text-align:center;"></i>
                <span>View Store</span>
            </a>
            <a asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "Customer" })" class="text-danger">
                <i class="fas fa-sign-out-alt" style="font-size:16px; width:20px; text-align:center;"></i>
                <span>Logout</span>
            </a>
        </div>

    </aside>

    <!-- ═══ TOPBAR ═══ -->
    <header class="km-topbar" id="kmTopbar">
        <div class="km-topbar-left">
            <button class="km-toggle-btn" onclick="toggleSidebar()" title="Toggle sidebar" aria-label="Toggle sidebar">
                <i class="fas fa-bars"></i>
            </button>
            <div class="km-breadcrumb" aria-label="Breadcrumb">
                <span>KiddoMart</span>
                <span class="km-breadcrumb-sep">/</span>
                <span class="km-breadcrumb-current">@RenderSection("Title", false)</span>
                @if (IsSectionDefined("SubTitle"))
                {
                    <span class="km-breadcrumb-sep">/</span>
                    <span class="km-breadcrumb-current">@RenderSection("SubTitle", false)</span>
                }
            </div>
        </div>

        <div class="km-topbar-right">
            <button class="km-icon-btn" title="Notifications" aria-label="Notifications" onclick="openNotifPanel()">
                <i class="far fa-bell"></i>
                <span class="km-badge"></span>
            </button>
            <div class="km-topbar-divider"></div>
            <div class="km-topbar-avatar" title="@adminDisplayName" aria-label="Admin user: @adminDisplayName">@adminInitials</div>
        </div>
    </header>

    <!-- ═══ MAIN CONTENT ═══ -->
    <main class="km-main" id="kmMain" role="main">

        <div class="km-page-header">
            <div>@RenderSection("ActionBtn", false)</div>
        </div>

        <div class="km-content-body">
            <div class="km-card">
                @RenderBody()
            </div>
        </div>

        <footer class="km-footer">
            <span>© 2026 <strong>KiddoMart</strong> — All rights reserved.</span>
            <span>Admin Panel v1.0</span>
        </footer>

    </main>

    <div class="km-notif-overlay" id="notifOverlay" onclick="closeNotifPanel()"></div>

    <div class="km-notif-panel" id="notifPanel" role="dialog" aria-label="Notifications">
        <div class="km-notif-header">
            <span>Notifications</span>
            <div class="d-flex gap-2 align-items-center">
                <button class="km-notif-markall" onclick="markAllRead()">Mark all read</button>
                <button class="km-notif-close" onclick="closeNotifPanel()" aria-label="Close notifications">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>
        <div class="km-notif-list" id="notifList"></div>
    </div>

    <!-- ═══ SCRIPTS ═══ -->
    <script src="~/Dashboard/plugins/jquery/jquery.min.js"></script>
    <script src="~/Dashboard/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/Dashboard/dist/js/adminlte.min.js"></script>
    <script src="~/Dashboard/plugins/sweetalert2/sweetalert2.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/Dashboard/dist/js/main.js"></script>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('kmSidebar');
            const topbar  = document.getElementById('kmTopbar');
            const main    = document.getElementById('kmMain');
            sidebar.classList.toggle('collapsed');
            topbar.classList.toggle('collapsed');
            main.classList.toggle('collapsed');
        }

        function toggleMenu(link, menuId) {
            event.preventDefault();
            const menu = document.getElementById(menuId);
            const isOpen = menu.classList.contains('open');
            document.querySelectorAll('.km-submenu.open').forEach(m => {
                m.classList.remove('open');
                m.previousElementSibling.classList.remove('open');
            });
            if (!isOpen) {
                menu.classList.add('open');
                link.classList.add('open');
            }
        }
    </script>

    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            $(document).ready(function () {
                toastr.options = { "closeButton": true, "progressBar": true, "positionClass": "toast-top-right", "timeOut": "5000", "newestOnTop": true };
                toastr.success('@Html.Raw(TempData["SuccessMessage"])');
            });
        </script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            $(document).ready(function () {
                toastr.options = { "closeButton": true, "progressBar": true, "positionClass": "toast-top-right", "timeOut": "5000" };
                toastr.error('@Html.Raw(TempData["ErrorMessage"])');
            });
        </script>
    }
    @if (TempData["WarningMessage"] != null)
    {
        <script>
            $(document).ready(function () {
                toastr.options = { "closeButton": true, "progressBar": true, "positionClass": "toast-top-right", "timeOut": "5000" };
                toastr.warning('@Html.Raw(TempData["WarningMessage"])');
            });
        </script>
    }
    @if (TempData["InfoMessage"] != null)
    {
        <script>
            $(document).ready(function () {
                toastr.options = { "closeButton": true, "progressBar": true, "positionClass": "toast-top-right", "timeOut": "5000" };
                toastr.info('@Html.Raw(TempData["InfoMessage"])');
            });
        </script>
    }

    @RenderSection("Scripts", false)

</body>
</html>
