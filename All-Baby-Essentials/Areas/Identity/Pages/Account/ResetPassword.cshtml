@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="auth-form-header">
    <div class="auth-icon"><i class="bi bi-lock-fill"></i></div>
    <h2>Set new password</h2>
    <p>Choose a strong password to protect your account.</p>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="km-validation-summary" role="alert">
        <div asp-validation-summary="ModelOnly"></div>
    </div>
}

<form method="post" novalidate>

    <input asp-for="Input.Code" type="hidden" />

    <div class="km-field">
        <input asp-for="Input.Email"
               type="email"
               id="reset-email"
               placeholder=" "
               autocomplete="username"
               aria-required="true" />
        <label for="reset-email">Email address</label>
        <span asp-validation-for="Input.Email" class="field-validation-error"></span>
    </div>

    <div class="km-field km-field-password">
        <input asp-for="Input.Password"
               type="password"
               id="reset-password"
               placeholder=" "
               autocomplete="new-password"
               aria-required="true" />
        <label for="reset-password">New password</label>
        <button type="button" class="km-pwd-toggle" aria-label="Show password">
            <i class="bi bi-eye"></i>
        </button>
        <span asp-validation-for="Input.Password" class="field-validation-error"></span>
        <div class="km-pwd-strength">
            <span class="km-pwd-strength-bar"></span>
            <span class="km-pwd-strength-bar"></span>
            <span class="km-pwd-strength-bar"></span>
            <span class="km-pwd-strength-bar"></span>
        </div>
    </div>

    <div class="km-field km-field-password" style="margin-bottom:1.5rem;">
        <input asp-for="Input.ConfirmPassword"
               type="password"
               id="reset-confirm"
               placeholder=" "
               autocomplete="new-password"
               aria-required="true" />
        <label for="reset-confirm">Confirm new password</label>
        <button type="button" class="km-pwd-toggle" aria-label="Show password">
            <i class="bi bi-eye"></i>
        </button>
        <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
    </div>

    <button type="submit" class="km-btn-auth primary">
        <i class="bi bi-check2-circle"></i>
        Reset Password
    </button>

</form>

<div class="auth-switch-text">
    <a asp-page="./Login" class="auth-link">Back to Sign In</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
