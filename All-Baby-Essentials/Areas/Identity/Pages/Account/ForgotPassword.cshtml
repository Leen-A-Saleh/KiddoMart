@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-form-header">
    <div class="auth-icon"><i class="bi bi-envelope-paper-fill"></i></div>
    <h2>Forgot your password?</h2>
    <p>No worries! Enter your email and we'll send you a reset link.</p>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="km-validation-summary" role="alert">
        <div asp-validation-summary="ModelOnly"></div>
    </div>
}

<form method="post" novalidate>

    <div class="km-field">
        <input asp-for="Input.Email"
               type="email"
               id="forgot-email"
               placeholder=" "
               autocomplete="username"
               aria-required="true" />
        <label for="forgot-email">Your email address</label>
        <span asp-validation-for="Input.Email" class="field-validation-error"></span>
    </div>

    <button type="submit" class="km-btn-auth primary" style="margin-top:0.5rem;">
        <i class="bi bi-send-fill"></i>
        Send Reset Link
    </button>

</form>

<div class="auth-switch-text">
    Remembered it?
    <a asp-page="./Login" class="auth-link">Back to Sign In</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
