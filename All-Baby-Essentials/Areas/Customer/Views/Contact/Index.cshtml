@{
    ViewData["Title"] = "Contact Us";
}

<!-- Page Header -->
<div class="km-page-header" data-aos="fade-down">
    <div class="container-fluid" style="max-width:1280px;">
        <h1>Contact Us</h1>
        <p>We'd love to hear from you. Get in touch with our team.</p>
        <div class="km-breadcrumb justify-content-center mt-3">
            <a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a>
            <span class="sep">/</span>
            <span style="color:#fff;">Contact</span>
        </div>
    </div>
</div>

<div class="container-fluid" style="max-width:1280px; margin-bottom:5rem; margin-top:3rem;">
    <div class="row g-5">
        <!-- Contact Form -->
        <div class="col-lg-7" data-aos="fade-right">
            <div class="bg-white p-4 p-md-5 rounded-4 shadow-sm border h-100">
                <h2 class="mb-4" style="color:var(--km-primary);">Send Us a Message</h2>
                <p class="text-muted mb-4">Have a question about a product, order, or anything else? Fill out the form below and our team will get back to you as soon as possible.</p>
                
                <form action="#" method="post" id="contact_form">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="km-label">Full Name</label>
                            <input type="text" name="name" class="km-form-control" placeholder="John Doe" required />
                        </div>
                        <div class="col-md-6">
                            <label class="km-label">Email Address</label>
                            <input type="email" name="email" class="km-form-control" placeholder="john@example.com" required />
                        </div>
                        <div class="col-md-6">
                            <label class="km-label">Phone Number</label>
                            <input type="tel" name="phone" class="km-form-control" placeholder="+1 (555) 000-0000" />
                        </div>
                        <div class="col-md-6">
                            <label class="km-label">Subject</label>
                            <input type="text" name="subject" class="km-form-control" placeholder="How can we help?" required />
                        </div>
                        <div class="col-12">
                            <label class="km-label">Message</label>
                            <textarea name="message" rows="6" class="km-form-control" placeholder="Write your message here..." required></textarea>
                        </div>
                        <div class="col-12 mt-4">
                            <button type="submit" class="km-btn km-btn-primary km-btn-lg px-5">
                                <i class="bi bi-send me-2"></i> Send Message
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Contact Information -->
        <div class="col-lg-5" data-aos="fade-left">
            <div class="bg-light p-4 p-md-5 rounded-4 border h-100 d-flex flex-column">
                <h3 class="mb-4" style="color:var(--km-primary);">Get In Touch</h3>
                
                <div class="d-flex align-items-start mb-4 gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:50px; height:50px; background:var(--km-primary-light); color:#fff; flex-shrink:0;">
                        <i class="bi bi-geo-alt fs-4"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1">Our Store</h5>
                        <p class="text-muted mb-0">123 Baby Essentials Ave<br>Toronto, ON M5V 2T6<br>Canada</p>
                    </div>
                </div>

                <div class="d-flex align-items-start mb-4 gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:50px; height:50px; background:var(--km-primary-light); color:#fff; flex-shrink:0;">
                        <i class="bi bi-telephone fs-4"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1">Call Us</h5>
                        <p class="text-muted mb-0">+1 (440) 000-0000<br>Mon - Sat: 9am - 6pm</p>
                    </div>
                </div>

                <div class="d-flex align-items-start mb-4 gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:50px; height:50px; background:var(--km-primary-light); color:#fff; flex-shrink:0;">
                        <i class="bi bi-envelope fs-4"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1">Email Us</h5>
                        <p class="text-muted mb-0">support@kiddomart.com<br>sales@kiddomart.com</p>
                    </div>
                </div>

                <hr class="my-4" style="border-color:var(--km-border);">
                
                <h5 class="fw-bold mb-3">Follow Us</h5>
                <div class="d-flex gap-2">
                    <a href="#" class="km-btn km-btn-outline" style="width:40px; height:40px; padding:0; display:flex; align-items:center; justify-content:center; border-radius:50%;"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="km-btn km-btn-outline" style="width:40px; height:40px; padding:0; display:flex; align-items:center; justify-content:center; border-radius:50%;"><i class="bi bi-twitter"></i></a>
                    <a href="#" class="km-btn km-btn-outline" style="width:40px; height:40px; padding:0; display:flex; align-items:center; justify-content:center; border-radius:50%;"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="km-btn km-btn-outline" style="width:40px; height:40px; padding:0; display:flex; align-items:center; justify-content:center; border-radius:50%;"><i class="bi bi-pinterest"></i></a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Map Section -->
    <div class="row mt-5" data-aos="fade-up">
        <div class="col-12">
            <div class="rounded-4 overflow-hidden shadow-sm border" style="height:400px; background:#e9ecef; position:relative;">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2887.2685934522883!2d-79.39864238450257!3d43.64256617912168!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x882b34d2a33d602f%3A0x1b1932145db422e6!2sSpadina%20Ave.%2C%20Toronto%2C%20ON%2C%20Canada!5e0!3m2!1sen!2sus!4v1620000000000!5m2!1sen!2sus" 
                        width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
            </div>
        </div>
    </div>
</div>
