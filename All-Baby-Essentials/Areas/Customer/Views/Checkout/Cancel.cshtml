@{
    ViewData["Title"] = "Order Cancelled";
}

<div class="km-container" style="padding: 5rem 1.5rem; text-align: center;">
    <div class="km-cancel-wrapper km-fade-up">
        <div class="km-cancel-icon"><i class="bi bi-x-circle"></i></div>

        <h1 style="font-size:2rem; margin:1.5rem 0 0.75rem; color:var(--km-text);">
            Payment Cancelled
        </h1>
        <p style="color:var(--km-muted); font-size:1.05rem; max-width:440px; margin:0 auto 2.5rem; line-height:1.7;">
            Your order was not completed. No charges were made to your account.
            Ready to try again?
        </p>

        <div class="km-cancel-tips">
            <div class="km-cancel-tip">
                <i class="bi bi-shield-check"></i>
                <span>Your payment details are secure</span>
            </div>
            <div class="km-cancel-tip">
                <i class="bi bi-bag-heart"></i>
                <span>Your cart items are still saved</span>
            </div>
            <div class="km-cancel-tip">
                <i class="bi bi-headset"></i>
                <span>Need help? Contact our support</span>
            </div>
        </div>

        <div class="km-cancel-actions">
            <a asp-area="Customer" asp-controller="Cart" asp-action="Index"
               class="km-btn km-btn-primary km-btn-lg">
                <i class="bi bi-arrow-left"></i> Back to Cart
            </a>
            <a asp-area="Customer" asp-controller="Product" asp-action="Index"
               class="km-btn km-btn-ghost km-btn-lg">
                <i class="bi bi-shop"></i> Browse Products
            </a>
            <a asp-area="Customer" asp-controller="Contact" asp-action="Index"
               class="km-btn km-btn-ghost km-btn-lg">
                <i class="bi bi-envelope"></i> Contact Support
            </a>
        </div>
    </div>
</div>

<style>
.km-cancel-wrapper { max-width: 540px; margin: 0 auto; }
.km-cancel-icon {
    width: 100px; height: 100px; border-radius: 50%;
    background: #FEF2F2;
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem; color: #EF4444; margin: 0 auto;
    animation: pop 0.4s cubic-bezier(0.34,1.56,0.64,1) both;
}
@@keyframes pop { from { transform: scale(0); } to { transform: scale(1); } }
.km-cancel-tips {
    display: flex; flex-direction: column; gap: 0.75rem;
    background: var(--km-surface); border-radius: var(--km-radius);
    padding: 1.5rem; margin-bottom: 2.5rem;
    border: 1px solid var(--km-border);
    text-align: left;
}
.km-cancel-tip {
    display: flex; align-items: center; gap: 0.75rem;
    font-size: 0.875rem; color: var(--km-text-2);
}
.km-cancel-tip i { font-size: 1.1rem; color: var(--km-pink); }
.km-cancel-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
</style>
