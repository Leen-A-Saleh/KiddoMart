@model All_Baby_Essentials.Areas.Customer.ViewModels.CheckoutViewModel

<div id="page-content">

    <!-- Breadcrumbs -->
    <div class="breadcrumbs-wrapper">
        <div class="container">
            <div class="breadcrumbs">
                <a href="/">Home</a>
                <span>|</span>
                <span>Checkout</span>
            </div>
        </div>
    </div>

    <div class="page-title">
        <h1>Checkout</h1>
    </div>

    <div class="container">

        <div class="row">

            <!-- LEFT -->
            <div class="col-lg-7">

                <div class="card shadow-sm mb-4">

                    <div class="card-body">

                        <h3 class="mb-4">
                            Billing Details
                        </h3>

                        <form id="checkoutForm"
                              asp-area="Customer"
                              asp-controller="Checkout"
                              asp-action="Checkout"
                              method="post">

                            <div class="row">

                                <div class="form-group col-md-6 mb-3">

                                    <label>Full Name *</label>

                                    <input asp-for="FullName"
                                           class="form-control" />

                                    <span asp-validation-for="FullName"
                                          class="text-danger"></span>

                                </div>

                                <div class="form-group col-md-6 mb-3">

                                    <label>Email *</label>

                                    <input asp-for="Email"
                                           class="form-control" />

                                    <span asp-validation-for="Email"
                                          class="text-danger"></span>

                                </div>

                            </div>

                            <div class="row">

                                <div class="form-group col-md-6 mb-3">

                                    <label>Phone Number *</label>

                                    <input asp-for="PhoneNumber"
                                           class="form-control" />

                                    <span asp-validation-for="PhoneNumber"
                                          class="text-danger"></span>

                                </div>

                                <div class="form-group col-md-6 mb-3">

                                    <label>City *</label>

                                    <input asp-for="City"
                                           class="form-control" />

                                    <span asp-validation-for="City"
                                          class="text-danger"></span>

                                </div>

                            </div>

                            <div class="row">

                                <div class="form-group col-md-12 mb-3">

                                    <label>Shipping Address *</label>

                                    <input asp-for="ShippingAddress"
                                           class="form-control" />

                                    <span asp-validation-for="ShippingAddress"
                                          class="text-danger"></span>

                                </div>

                            </div>

                            <div class="row">

                                <div class="form-group col-md-12 mb-3">

                                    <label>Country *</label>

                                    <input asp-for="Country"
                                           class="form-control" />

                                    <span asp-validation-for="Country"
                                          class="text-danger"></span>

                                </div>

                            </div>
                            
                            <!-- Payment Method Selection -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <h4 class="mb-3">Payment Method</h4>
                                    
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="Card" id="payCard" checked>
                                        <label class="form-check-label fw-bold" for="payCard">
                                            <i class="bi bi-credit-card me-2 text-primary"></i> Credit / Debit Card (Stripe)
                                        </label>
                                    </div>
                                    
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="COD" id="payCOD">
                                        <label class="form-check-label fw-bold" for="payCOD">
                                            <i class="bi bi-cash-coin me-2 text-success"></i> Cash on Delivery
                                        </label>
                                    </div>
                                    <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                                </div>
                            </div>

                        </form>

                    </div>

                </div>

            </div>

            <!-- RIGHT -->
            <div class="col-lg-5">

                <div class="card shadow-sm">

                    <div class="card-body">

                        <h3 class="mb-4">
                            Your Order
                        </h3>

                        <table class="table">

                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var item in Model.CartItems)
                                {
                                    <tr>

                                        <td>
                                            @item.ProductName
                                        </td>

                                        <td class="text-center">
                                            @item.Quantity
                                        </td>

                                        <td class="text-end">
                                            $@(item.Price* item.Quantity)
                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                        <hr />

                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal:</span>
                            <strong>$@Model.TotalPrice</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Shipping:</span>
                            <strong>Free</strong>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between mb-4">
                            <h5>Total:</h5>
                            <h5>$@Model.TotalPrice</h5>
                        </div>

                        <button type="submit"
                                form="checkoutForm"
                                id="checkoutSubmitBtn"
                                class="btn btn-success w-100 btn-lg fw-bold">

                            Pay With Card

                        </button>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const btn = document.getElementById('checkoutSubmitBtn');
            const cardRadio = document.getElementById('payCard');
            const codRadio = document.getElementById('payCOD');

            function updateBtn() {
                if (cardRadio.checked) {
                    btn.textContent = 'Pay With Card';
                    btn.className = 'btn btn-primary w-100 btn-lg fw-bold';
                } else {
                    btn.textContent = 'Place Order (Cash on Delivery)';
                    btn.className = 'btn btn-success w-100 btn-lg fw-bold';
                }
            }

            cardRadio.addEventListener('change', updateBtn);
            codRadio.addEventListener('change', updateBtn);
            updateBtn(); // Initial set
        });
    </script>
}
