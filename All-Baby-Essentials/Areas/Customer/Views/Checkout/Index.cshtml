@model All_Baby_Essentials.Areas.Customer.ViewModels.CheckoutViewModel

<div id="page-content">

    <!-- Page Header -->
    <div class="km-page-header" data-aos="fade-down" style="padding: 3rem 0; margin-bottom: 2rem;">
        <div class="container" style="max-width:1280px;">
            <h1>Secure Checkout</h1>
            <p>Complete your order securely and fast.</p>
            <div class="km-breadcrumb justify-content-center mt-3">
                <a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a>
                <span class="sep">/</span>
                <span style="color:#fff;">Checkout</span>
            </div>
        </div>
    </div>

    <div class="container">

        <div class="row">

            <!-- LEFT -->
            <div class="col-lg-7">

                <div class="card shadow-sm mb-4">

                    <div class="card-body">

                        <h3 class="mb-4">
                            Billing Details
                        </h3>

                        <form id="checkoutForm"
                              asp-area="Customer"
                              asp-controller="Checkout"
                              asp-action="Checkout"
                              method="post">

                            <div class="row">

                                <div class="col-md-6 mb-3">
                                    <label class="km-label">Full Name *</label>
                                    <input asp-for="FullName" class="km-form-control" />
                                    <span asp-validation-for="FullName" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="km-label">Email *</label>
                                    <input asp-for="Email" class="km-form-control" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                            </div>

                            <div class="row">

                                <div class="col-md-6 mb-3">
                                    <label class="km-label">Phone Number *</label>
                                    <input asp-for="PhoneNumber" class="km-form-control" />
                                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="km-label">City *</label>
                                    <input asp-for="City" class="km-form-control" />
                                    <span asp-validation-for="City" class="text-danger"></span>
                                </div>

                            </div>

                            <div class="row">

                                <div class="col-md-12 mb-3">
                                    <label class="km-label">Shipping Address *</label>
                                    <input asp-for="ShippingAddress" class="km-form-control" />
                                    <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                                </div>

                            </div>

                            <div class="row">

                                <div class="col-md-12 mb-3">
                                    <label class="km-label">Country *</label>
                                    <input asp-for="Country" class="km-form-control" />
                                    <span asp-validation-for="Country" class="text-danger"></span>
                                </div>

                            </div>
                            
                            <!-- Payment Method Selection -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <h4 class="mb-3">Payment Method</h4>
                                    
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="Card" id="payCard" checked>
                                        <label class="form-check-label fw-bold" for="payCard">
                                            <i class="bi bi-credit-card me-2 text-primary"></i> Credit / Debit Card (Stripe)
                                        </label>
                                    </div>
                                    
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="COD" id="payCOD">
                                        <label class="form-check-label fw-bold" for="payCOD">
                                            <i class="bi bi-cash-coin me-2 text-success"></i> Cash on Delivery
                                        </label>
                                    </div>
                                    <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                                </div>
                            </div>

                        </form>

                    </div>

                </div>

            </div>

            <!-- RIGHT -->
            <div class="col-lg-5">

                <div class="card shadow-sm">

                    <div class="card-body">

                        <h3 class="mb-4">
                            Your Order
                        </h3>

                        <table class="table">

                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var item in Model.CartItems)
                                {
                                    <tr>

                                        <td>
                                            @item.ProductName
                                        </td>

                                        <td class="text-center">
                                            @item.Quantity
                                        </td>

                                        <td class="text-end">
                                            $@(item.Price* item.Quantity)
                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                        <hr />

                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal:</span>
                            <strong>$@Model.TotalPrice</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Shipping:</span>
                            <strong>Free</strong>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between mb-4">
                            <h5>Total:</h5>
                            <h5>$@Model.TotalPrice</h5>
                        </div>

                        <button type="submit"
                                form="checkoutForm"
                                id="checkoutSubmitBtn"
                                class="km-btn km-btn-primary km-btn-block km-btn-lg mt-3">

                            Pay With Card

                        </button>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const btn = document.getElementById('checkoutSubmitBtn');
            const cardRadio = document.getElementById('payCard');
            const codRadio = document.getElementById('payCOD');

            function updateBtn() {
                if (cardRadio.checked) {
                    btn.innerHTML = '<i class="bi bi-credit-card me-2"></i> Pay With Card';
                    btn.className = 'km-btn km-btn-primary km-btn-block km-btn-lg mt-3';
                } else {
                    btn.innerHTML = '<i class="bi bi-cash-coin me-2"></i> Place Order (COD)';
                    btn.className = 'km-btn km-btn-accent km-btn-block km-btn-lg mt-3';
                }
            }

            cardRadio.addEventListener('change', updateBtn);
            codRadio.addEventListener('change', updateBtn);
            updateBtn(); // Initial set
        });
    </script>
}
