@model List<All_Baby_Essentials.Areas.Admin.ViewModels.CategoryVM>
@{
    ViewData["Title"] = "Categories";
}

<!-- Page Header -->
<div class="km-page-header" data-aos="fade-down">
    <div class="container-fluid" style="max-width:1280px;">
        <h1>Shop by Category</h1>
        <p>Explore our curated collections tailored for every need.</p>
        <div class="km-breadcrumb justify-content-center mt-3">
            <a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a>
            <span class="sep">/</span>
            <span style="color:#fff;">Categories</span>
        </div>
    </div>
</div>

<div class="container-fluid" style="max-width:1280px; margin-bottom:5rem;">
    <div class="row g-4">
        @foreach (var cat in Model)
        {
            var image = string.IsNullOrEmpty(cat.ImageUrl) ? "/img/no-image.png" : $"/img/{cat.ImageUrl}";

            <div class="col-12 col-sm-6 col-md-4 col-lg-3" data-aos="zoom-in" data-aos-delay="100">
                <a asp-area="Customer" asp-controller="Product" asp-action="Index" asp-route-categoryId="@cat.Id" class="text-decoration-none d-block h-100">
                    <div class="km-category-card position-relative overflow-hidden rounded-4 shadow-sm border h-100" style="aspect-ratio: 1; background:var(--km-bg);">
                        <img src="@image" alt="@cat.Name" class="w-100 h-100 object-fit-cover" style="transition: transform 0.5s ease;" />
                        
                        <div class="position-absolute bottom-0 start-0 w-100 p-4" style="background: linear-gradient(to top, rgba(15,23,42,0.8), transparent);">
                            <h3 class="text-white mb-1" style="font-size: 1.25rem;">@cat.Name</h3>
                            <span class="text-white opacity-75 small">@cat.Products.Count() Products</span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<style>
.km-category-card:hover img {
    transform: scale(1.1);
}
.km-category-card:hover {
    box-shadow: var(--km-shadow-lg) !important;
    border-color: var(--km-primary-light) !important;
}
</style>
