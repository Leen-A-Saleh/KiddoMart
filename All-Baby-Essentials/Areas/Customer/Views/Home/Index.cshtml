<!-- ══ TESTIMONIALS ══ -->
@if (Model.Testimonials.Any())
{
    var testimonialsList = Model.Testimonials.ToList();
    int chunkSize = 3;
    int chunksCount = (int)Math.Ceiling((double)testimonialsList.Count / chunkSize);

    <section class="py-5 my-5" aria-labelledby="testimonials-heading">
        <div class="container-fluid" style="max-width:1280px;">
            <div class="km-section-header" data-aos="fade-up">
                <span class="km-tag">Happy Parents</span>
                <h2 id="testimonials-heading">What Our Customers Say</h2>
            </div>
            
            <div id="testimonialCarousel" class="carousel slide px-4 px-md-5" data-bs-ride="carousel" data-aos="zoom-in" data-aos-delay="100">
                <div class="carousel-inner pb-5 pt-3">
                    @for (int idx = 0; idx < chunksCount; idx++)
                    {
                        <div class="carousel-item @(idx == 0 ? "active" : "")">
                            <div class="row justify-content-center g-4">
                                @for (int i = idx * chunkSize; i < Math.Min((idx + 1) * chunkSize, testimonialsList.Count); i++)
                                {
                                    var item = testimonialsList[i];
                                    <div class="col-md-4 col-12">
                                        <div class="bg-white p-4 rounded-4 shadow-sm border h-100 d-flex flex-column text-center">
                                            <div class="d-flex justify-content-center mb-3" style="color:var(--km-gold);">
                                                @for (int r = 1; r <= 5; r++)
                                                {
                                                    <i class="bi @(r <= item.Rating ? "bi-star-fill" : "bi-star") mx-1 fs-5"></i>
                                                }
                                            </div>
                                            <p class="text-muted mb-4 flex-grow-1 fst-italic" style="font-size:1.05rem; line-height:1.6;">"@item.Content"</p>
                                            <div class="d-flex flex-column align-items-center justify-content-center gap-2 mt-2">
                                                <div class="rounded-circle text-white d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width:48px; height:48px; background:var(--km-primary); font-size:1.2rem;">
                                                    @(string.IsNullOrWhiteSpace(item.User?.FullName) ? "U" : item.User.FullName.Substring(0, 1).ToUpper())
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark fs-5">@item.User?.FullName</div>
                                                    <div class="small text-muted">Verified Buyer</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                
                <div class="carousel-indicators" style="bottom: -10px;">
                    @for (int idx = 0; idx < chunksCount; idx++)
                    {
                        <button type="button" data-bs-target="#testimonialCarousel" data-bs-slide-to="@idx" class="@(idx == 0 ? "active" : "")" aria-current="@(idx == 0 ? "true" : "false")" aria-label="Slide @(idx + 1)" style="background-color: var(--km-primary); width: 10px; height: 10px; border-radius: 50%;"></button>
                    }
                </div>
                
                <button class="carousel-control-prev" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="prev" style="width: 5%; opacity: 1;">
                    <div class="bg-white rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; border: 1px solid var(--km-border);">
                        <i class="bi bi-chevron-left text-dark fs-4"></i>
                    </div>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="next" style="width: 5%; opacity: 1;">
                    <div class="bg-white rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; border: 1px solid var(--km-border);">
                        <i class="bi bi-chevron-right text-dark fs-4"></i>
                    </div>
                </button>
            </div>
            
        </div>
    </section>
}

<!-- ══ ADD TESTIMONIAL ══ -->
@if (User.Identity!.IsAuthenticated)
{
    <section class="py-5 bg-white" aria-labelledby="add-testimonial-heading">
        <div class="container-fluid" style="max-width:600px;" data-aos="fade-up">
            <div class="km-section-header mb-4">
                <span class="km-tag">Share Your Experience</span>
                <h2 id="add-testimonial-heading">Leave a Testimonial</h2>
            </div>
            <div class="bg-white p-4 p-md-5 rounded-4 shadow-lg border border-light">
                <form asp-action="AddTestimonial" method="post">
                    <div class="mb-4">
                        <label for="testimonial-content" class="km-label">Your message</label>
                        <textarea id="testimonial-content" name="content" rows="4" class="km-form-control" placeholder="Tell us about your experience..." required aria-required="true"></textarea>
                    </div>
                    <div class="mb-4">
                        <label for="testimonial-rating" class="km-label">Rating</label>
                        <select id="testimonial-rating" name="rating" class="km-form-control" required aria-required="true">
                            <option value="">Select a rating</option>
                            <option value="5">⭐⭐⭐⭐⭐ — Excellent</option>
                            <option value="4">⭐⭐⭐⭐ — Very Good</option>
                            <option value="3">⭐⭐⭐ — Good</option>
                            <option value="2">⭐⭐ — Fair</option>
                            <option value="1">⭐ — Poor</option>
                        </select>
                    </div>
                    <button type="submit" class="km-btn km-btn-primary km-btn-block km-btn-lg">
                        <i class="bi bi-send"></i> Submit Testimonial
                    </button>
                </form>
            </div>
        </div>
    </section>
}
